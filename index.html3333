// вФАвФАвФАвФА BONE DATABASE вФАвФАвФАвФА
// вФАвФАвФАвФА BONE SYSTEM вФАвФАвФАвФА
// Bone tier power ranges: [зЩЊеєі100-200, еНГеєі500-1000, дЄЗеєі5000-8000, еНБдЄЗеєі10000-15000, зЩЊдЄЗеєі20000-30000, дЄНеПѓдЉ∞йЗП40000-50000, з•ЮиµР1000000]
const BONE_TIER_PW={
  "зЩЊеєі":    [150,  180],
  "еНГеєі":    [900,  1100],
  "дЄЗеєі":    [5200, 5800],
  "еНБдЄЗеєі":  [12500,13500],
  "зЩЊдЄЗеєі":  [26000,27500],
  "дЄНеПѓдЉ∞йЗП":[47000,49500],
  "з•ЮиµР":    [1000000,1000000]
};
function genBonePw(ringYear){
  const r=BONE_TIER_PW[ringYear]||[100,200];
  return ri(r[0],r[1]);
}

