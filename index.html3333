        </div>
      </div>
    </div>
    <div class="card">
      <div class="st" style="margin-bottom:8px">жЈїеК†иНѓиНЙпЉИеПѓйАЙпЉЙ</div>
      <div class="fh-row">
        <div class="fhs" onclick="addFH(0)" id="fhs-0"><span>+</span></div>
        <div class="fhs" onclick="addFH(1)" id="fhs-1"><span>+</span></div>
        <div class="fhs" onclick="addFH(2)" id="fhs-2"><span>+</span></div>
      </div>
    </div>
    <div class="card">
      <div class="fr-row"><span class="fr-l">еЯЇз°АжИРеКЯзОЗ</span><span class="fr-v" id="fr-b">50%</span></div>
      <div class="fr-row"><span class="fr-l">иНѓиНЙеК†жИР</span><span class="fr-v" id="fr-h">+0%</span></div>
      <div class="fr-row"><span class="fr-l">жЬАзїИжИРеКЯзОЗ</span><span class="fr-v" id="fr-f">50%</span></div>
      <div class="fr-row"><span class="fr-l">иі®еПШж¶ВзОЗ</span><span class="fr-v" id="fr-m">1%</span></div>
      <div class="fr-row"><span class="fr-l">иНѓиНЙиі®еПШеК†жИР</span><span class="fr-v" id="fr-hm">+0%</span></div>
    </div>
