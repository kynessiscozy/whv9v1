   desc:"жЄЄиµ∞дЇОзІ©еЇПиІДеИЩдєЛе§ЦпЉМйАЪињЗжЈЈж≤МиѓХзВЉиОЈеПЦжЈЈж≤МдєЛеКЫгАВ",
   unlock:()=>G.soul&&((G.soul.attrs&&G.soul.attrs.some(a=>a.includes('жЈЈж≤М')))||(G.soul.name&&G.soul.name.includes('жЈЈж≤М'))||['apex','hc','ha','twin','triple'].includes(G.soul.quality)),
   trials:[
    {n:"жЈЈж≤МжДЯзЯ•",d:"жДЯеПЧжЈЈж≤МжµБеК®пЉМиЃ©жАЭзїіињЫеЕ•жЧ†еЇПзКґжАБгАВ",rew:"зїПй™М+3000,жИШеКЫ+500",cost:600},
    {n:"жЈЈж≤МеЕ±йЄ£",d:"дЄОжЈЈж≤МиГљйЗПдЇІзФЯеЕ±йЄ£пЉМиОЈеПЦжЈЈж≤МеИЭеІЛдєЛеКЫгАВ",rew:"зїПй™М+6000,жИШеКЫ+1200,жЈЈж≤МжЩґж†Є√Ч3",cost:1000},
    {n:"жЈЈж≤Мж≥ХеИЩиІ¶зҐ∞",d:"дЄїеК®иІ¶зҐ∞жЈЈж≤Мж≥ХеИЩиЊєзХМпЉМжЙњеПЧжЈЈж≤МеЖ≤еЗїгАВ",rew:"зїПй™М+12000,жИШеКЫ+3000,зЙєжЃКе±ЮжАІеҐЮеєЕ",cost:1500},
    {n:"жЈЈж≤МеМЦиЇЂ",d:"е∞ЖжЈЈж≤МдєЛеКЫиЮНеЕ•ж≠¶й≠ВпЉМжИРдЄЇжЈЈж≤МзЪДдї£и®АдЇЇгАВ",rew:"зїПй™М+25000,жИШеКЫ+8000,жЈЈж≤Мй≠Вй™®",cost:2500},
   ]},
  {id:"p_hidden",n:"йЪРиЧПдєЛиЈѓ",i:"рЯФЃ",col:"#10b981",req:"йЪРиЧПж≠¶й≠В",
   desc:"йЪРиЧПж≠¶й≠ВжМБжЬЙиАЕзЛђжЬЙзЪДз•ЮзІШйБУиЈѓпЉМйАЪеРСдЄНдЄЇдЇЇзЯ•зЪДеКЫйЗПдєЛжЇРгАВ",
   unlock:()=>G.soul&&(G.soul.divine||['hc','ha'].includes(G.soul.quality)||(['apex'].includes(G.soul.quality)&&G.soul.secondAwakened)),
   trials:[
