<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<title>жЦЧзљЧе§ІйЩЖ ¬Ј ж≠¶й≠ВиІЙйЖТ</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=Noto+Sans+SC:wght@300;400;500;700&display=swap');
:root{
  --gold:#c9a227;--gl:#f0d060;--gd:#8a6e1a;
  --bg:#050810;--bgc:#0f1628;--bgc2:#141c35;
  --txt:#e8dfc0;--dim:#626870;
  --bdr:rgba(201,162,39,.2);--bdrB:rgba(201,162,39,.52);
  --common:#9ca3af;--rare:#3b82f6;--epic:#8b5cf6;--legend:#f59e0b;--apex:#ef4444;
  --hc:#10b981;--ha:#ec4899;--twin:#f0abfc;--triple:#e2e8f0;--divine:#ffd700;
  --r100:#a78bfa;--r1k:#60a5fa;--r10k:#34d399;--r100k:#fbbf24;
  --r1m:#f87171;--rUnk:#e879f9;--rGod:#fffbeb;--rCosmic:#00ffff;
  --herb:#22c55e;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);font-family:'Noto Sans SC',sans-serif;color:var(--txt);user-select:none}
canvas#C{position:fixed;inset:0;z-index:0;pointer-events:none}
#SB{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden}
.star{position:absolute;background:#fff;border-radius:50%;animation:twk var(--d) ease infinite var(--dl)}
@keyframes twk{0%,100%{opacity:var(--mn)}50%{opacity:var(--mx)}}
#app{position:relative;z-index:1;width:100%;height:100%;display:flex;flex-direction:column;max-width:430px;margin:0 auto;background:linear-gradient(180deg,#050810,#08101a)}

/* TOP BAR */
#topbar{flex-shrink:0;background:linear-gradient(180deg,rgba(5,8,16,.98),rgba(10,15,30,.95));border-bottom:1px solid var(--bdr);padding:9px 14px 7px;z-index:50}
.tb-row{display:flex;align-items:center;justify-content:space-between}
.tb-title{font-family:'Ma Shan Zheng',serif;font-size:19px;background:linear-gradient(135deg,var(--gl),var(--gold),var(--gd));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:3px}
.tb-pills{display:flex;gap:6px}
.pill{display:flex;align-items:center;gap:3px;background:rgba(201,162,39,.09);border:1px solid var(--bdr);border-radius:20px;padding:2px 8px;font-size:10px;color:var(--gl)}
.pill.pow{border-color:rgba(239,68,68,.35);background:rgba(239,68,68,.07);color:#fca5a5}
.exp-row{margin-top:6px;display:flex;align-items:center;gap:7px}
.exp-wrap{flex:1;height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden}
.exp-fill{height:100%;background:linear-gradient(90deg,var(--gd),var(--gl));border-radius:2px;transition:width .6s ease}
.exp-lbl{font-size:9px;color:var(--dim);white-space:nowrap;min-width:75px;text-align:right}

/* NOTIF */
/* вФАвФА Notification system v7 вФАвФА */
#notif{
  position:fixed;top:70px;right:10px;z-index:300;
  width:222px;max-width:calc(100% - 20px);
  display:flex;flex-direction:column;gap:5px;
  pointer-events:none;align-items:flex-end;
}
.ntf{
  display:flex;align-items:center;gap:7px;
  padding:7px 11px 7px 9px;border-radius:22px;
  font-size:10px;line-height:1.35;font-weight:500;
  max-width:100%;word-break:break-all;
  backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
  background:rgba(8,14,30,.85);
  border:1px solid rgba(201,162,39,.28);
  box-shadow:0 2px 12px rgba(0,0,0,.5),0 0 10px rgba(201,162,39,.12);
  animation:ntfIn .28s cubic-bezier(.34,1.56,.64,1) both,ntfOut .35s ease 2.95s forwards;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.ntf::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0;background:var(--ntf-col,var(--gl));box-shadow:0 0 5px var(--ntf-col,var(--gl))}
.ntf.long{white-space:normal;border-radius:12px;padding:8px 12px 8px 10px;align-items:flex-start}
.ntf.long::before{margin-top:3px}
.ntf.normal{--ntf-col:rgba(201,162,39,.75);color:rgba(255,255,255,.62)}
.ntf.epic{--ntf-col:#a78bfa;border-color:rgba(139,92,246,.38);background:rgba(10,6,24,.88);box-shadow:0 2px 12px rgba(0,0,0,.5),0 0 10px rgba(139,92,246,.16);color:rgba(255,255,255,.82)}
.ntf.legend{--ntf-col:#f59e0b;border-color:rgba(245,158,11,.42);background:rgba(18,12,2,.88);box-shadow:0 2px 14px rgba(0,0,0,.5),0 0 14px rgba(245,158,11,.2);color:#fef3c7}
.ntf.divine{--ntf-col:#ffd700;border-color:rgba(255,215,0,.5);background:rgba(16,14,2,.9);box-shadow:0 2px 16px rgba(0,0,0,.55),0 0 18px rgba(255,215,0,.25);color:#fef9c3}
.ntf.cosmic{--ntf-col:#00ffff;border-color:rgba(0,255,255,.52);background:rgba(0,10,14,.92);box-shadow:0 2px 20px rgba(0,0,0,.6),0 0 22px rgba(0,255,255,.28);color:#e0fffe}
@keyframes ntfIn{from{opacity:0;transform:translateX(14px) scale(.93)}to{opacity:1;transform:translateX(0) scale(1)}}
@keyframes ntfOut{to{opacity:0;transform:translateX(10px) scale(.95)}}

/* CONTENT */
#content{flex:1;overflow-y:auto;overflow-x:hidden;padding:0 0 66px;-webkit-overflow-scrolling:touch}
#content::-webkit-scrollbar{display:none}

/* BOTTOM NAV */
#bnav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:linear-gradient(0deg,rgba(5,8,16,.99),rgba(10,15,28,.96));border-top:1px solid var(--bdr);display:flex;z-index:50;height:58px}
.ni{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;cursor:pointer;transition:all .2s;position:relative}
.ni .ico{width:22px;height:22px;display:flex;align-items:center;justify-content:center;transition:transform .2s;color:var(--dim);flex-shrink:0}
.ni .ico svg{width:100%;height:100%;display:block;}
.ni .lbl{font-size:9px;color:var(--dim);letter-spacing:.3px}
.ni.active .lbl{color:var(--gl)}
.ni.active .ico{transform:scale(1.1);color:var(--gl)}
.ni.active::after{content:'';position:absolute;bottom:0;left:18%;right:18%;height:2px;background:linear-gradient(90deg,var(--gd),var(--gl));border-radius:2px 2px 0 0}

/* PAGE */
.page{display:none;padding:11px}
#page-soul{padding:0}
.page.active{display:block}
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.st{font-family:'Ma Shan Zheng',serif;font-size:14px;color:var(--gl);display:flex;align-items:center;gap:5px}
.st::before{content:'';width:3px;height:13px;background:linear-gradient(180deg,var(--gl),var(--gd));border-radius:2px}

/* CARD */
.card{background:linear-gradient(135deg,var(--bgc),var(--bgc2));border:1px solid var(--bdr);border-radius:12px;padding:12px;margin-bottom:10px;position:relative;overflow:hidden}
.card::before{content:'';position:absolute;inset:0;border-radius:12px;background:linear-gradient(135deg,rgba(201,162,39,.035),transparent 55%);pointer-events:none}

/* QUALITY COLORS */

/* ===== AWAKEN SCREEN ===== */
#SA{position:fixed;inset:0;z-index:200;background:radial-gradient(ellipse at 50% 38%,rgba(18,26,50,.98),#050810);display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden}
.aw-glow{position:absolute;width:320px;height:320px;border-radius:50%;background:radial-gradient(ellipse,rgba(201,162,39,.1),transparent 70%);animation:awG 3s ease infinite}
@keyframes awG{0%,100%{transform:scale(1);opacity:.5}50%{transform:scale(1.18);opacity:1}}
.aw-t{font-family:'Ma Shan Zheng',serif;font-size:28px;color:var(--gl);letter-spacing:7px;margin-bottom:5px;position:relative;z-index:1}
.aw-s{font-size:11px;color:var(--dim);margin-bottom:38px;z-index:1;letter-spacing:2px}
.aw-c{width:195px;height:195px;border-radius:50%;border:1.5px solid var(--bdrB);display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;background:radial-gradient(ellipse,rgba(18,26,50,.95),#050810);cursor:pointer;margin-bottom:28px;z-index:1;transition:all .3s}
.aw-c:active{transform:scale(.96)}
.ar1{position:absolute;inset:-10px;border-radius:50%;border:1px solid rgba(201,162,39,.18);animation:rot 9s linear infinite}
.ar2{position:absolute;inset:-20px;border-radius:50%;border:1px dashed rgba(124,58,237,.22);animation:rot 14s linear infinite reverse}
.ar3{position:absolute;inset:-32px;border-radius:50%;border:1px solid rgba(201,162,39,.07);animation:rot 21s linear infinite}
@keyframes rot{to{transform:rotate(360deg)}}
.aw-ico{font-size:70px;margin-bottom:3px}
.aw-hint{font-size:11px;color:var(--dim);animation:blk 1.8s infinite}
@keyframes blk{0%,100%{opacity:.3}50%{opacity:1}}
.aw-btn{padding:13px 38px;border-radius:12px;border:1px solid var(--bdrB);background:linear-gradient(135deg,rgba(201,162,39,.17),rgba(201,162,39,.05));color:var(--gl);font-size:16px;font-family:'Ma Shan Zheng',serif;letter-spacing:5px;cursor:pointer;transition:all .3s;z-index:1}
.aw-btn:hover{box-shadow:0 0 20px rgba(201,162,39,.38)}

/* ===== RESULT OVERLAY ===== */
#OR{position:fixed;inset:0;z-index:250;background:rgba(0,0,0,.91);display:none;flex-direction:column;align-items:center;justify-content:center;cursor:pointer}
#OR.show{display:flex}
.or-b{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 38%,var(--bc,rgba(201,162,39,.28)),transparent 62%);animation:bP .9s ease infinite;pointer-events:none}
@keyframes bP{0%,100%{opacity:.6;transform:scale(1)}50%{opacity:1;transform:scale(1.07)}}
.or-ico{font-size:86px;margin-bottom:14px;z-index:1;animation:flt 2s ease infinite}
@keyframes flt{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.or-q{font-family:'Ma Shan Zheng',serif;font-size:17px;letter-spacing:4px;margin-bottom:4px;z-index:1}
.or-nm{font-family:'Ma Shan Zheng',serif;font-size:34px;font-weight:900;margin-bottom:7px;z-index:1;letter-spacing:3px}
.or-desc{font-size:11px;color:var(--dim);max-width:270px;text-align:center;line-height:1.7;margin-bottom:14px;z-index:1}
.or-stats{display:flex;gap:10px;margin-bottom:18px;z-index:1}
.or-st{background:rgba(201,162,39,.1);border:1px solid var(--bdr);border-radius:8px;padding:6px 14px;text-align:center}
.or-st .v{font-size:20px;font-weight:700;color:var(--gl)}
.or-st .l{font-size:9px;color:var(--dim)}
.or-tap{font-size:11px;color:var(--dim);animation:blk 1.5s infinite;z-index:1}

/* ===== SOUL PAGE ===== */

.tbadge{font-size:9px;padding:2px 7px;border-radius:20px;background:rgba(201,162,39,.11);border:1px solid var(--bdrB);color:var(--gl);font-weight:600}

.sh-exp .sh-exp-row{display:flex;justify-content:space-between;margin-bottom:3px}
.sh-el{font-size:10px;color:var(--dim)}
.sh-ev{font-size:10px;color:var(--gl);font-weight:600}

.sb:active{transform:scale(.97)}
.sb.gold{background:rgba(201,162,39,.11);border-color:var(--bdrB);color:var(--gl)}
.sb.purple{background:rgba(124,58,237,.1);border-color:rgba(124,58,237,.4);color:#c4b5fd}
.sb.green{background:rgba(16,185,129,.08);border-color:rgba(16,185,129,.3);color:#6ee7b7}
.sb.blue{background:rgba(59,130,246,.08);border-color:rgba(59,130,246,.3);color:#93c5fd}
.sb.red{background:rgba(220,38,38,.06);border-color:rgba(220,38,38,.22);color:#f87171;font-size:10px}

/* RING ROW */

.rdot.empty{background:rgba(255,255,255,.04)}

/* SKILLS */
.skill-item{background:rgba(124,58,237,.07);border:1px solid rgba(124,58,237,.18);border-radius:8px;padding:8px 10px;margin-bottom:6px}
.ski-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:3px}
.ski-name{font-size:12px;font-weight:700;color:#c4b5fd}
.ski-ring{font-size:9px;color:var(--dim);background:rgba(124,58,237,.15);border-radius:4px;padding:1px 5px}
.ski-desc{font-size:10px;color:var(--dim);line-height:1.55;margin-bottom:5px}
.ski-params{display:flex;gap:5px;flex-wrap:wrap}
.ski-p{font-size:9px;background:rgba(124,58,237,.14);border-radius:4px;padding:1px 6px;color:#a78bfa}

/* BONE SYSTEM */
.bone-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}

.bone-slot:hover{border-color:var(--bdrB)}
.bone-slot.filled{border-color:rgba(251,191,36,.4);background:rgba(251,191,36,.05)}
.bone-slot.special-filled{border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.05)}

/* Special bone effects */

/* ARTIFACT */
.art-row{display:flex;align-items:center;gap:9px;background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.18);border-radius:9px;padding:9px 11px;margin-bottom:7px}
.art-i{font-size:26px;flex-shrink:0}
.art-inf{flex:1}
.art-nm{font-size:12px;font-weight:700;color:var(--legend)}
.art-d{font-size:10px;color:var(--dim);margin-top:1px}
.art-pw{font-size:10px;color:var(--gold);margin-top:2px}
.art-btn{padding:4px 10px;border-radius:7px;font-size:10px;font-weight:700;border:1px solid var(--bdrB);background:rgba(201,162,39,.1);color:var(--gl);cursor:pointer;flex-shrink:0}
.art-btn.rm{border-color:rgba(220,38,38,.3);background:rgba(220,38,38,.06);color:#f87171}
.art-btn:active{opacity:.7}

/* ===== HUNT / TRIALS PAGE ===== */
.zone-card{border-radius:12px;padding:14px;margin-bottom:9px;position:relative;overflow:hidden;cursor:pointer;transition:all .22s}
.zone-card:active{transform:scale(.98)}
.zone-card.forest{background:linear-gradient(135deg,rgba(3,22,10,.97),rgba(0,15,8,.99));border:1px solid rgba(16,185,129,.28)}
.zone-card.chaos{background:linear-gradient(135deg,rgba(42,8,70,.92),rgba(25,4,55,.96));border:1px solid rgba(139,92,246,.32)}
.zone-card.primordial{background:linear-gradient(135deg,rgba(0,25,45,.97),rgba(0,12,30,.99));border:1px solid rgba(6,182,212,.28)}
.zone-card.random{background:linear-gradient(135deg,rgba(38,26,3,.97),rgba(22,16,2,.99));border:1px solid rgba(201,162,39,.28)}
.zone-card.godpath{background:linear-gradient(135deg,rgba(80,0,0,.95),rgba(50,0,0,.98));border:1px solid rgba(239,68,68,.5);box-shadow:0 0 20px rgba(239,68,68,.15)}
.zone-card.godpath.locked{opacity:.5;filter:grayscale(.6)}
.z-deco{position:absolute;right:-8px;top:-8px;font-size:72px;opacity:.05;pointer-events:none}
.z-ico{font-size:30px;margin-bottom:6px}
.z-nm{font-family:'Ma Shan Zheng',serif;font-size:17px;font-weight:700;margin-bottom:3px;letter-spacing:2px}
.z-desc{font-size:10px;color:var(--dim);line-height:1.6;margin-bottom:9px}
.z-tags{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:9px}
.ztag{font-size:9px;padding:2px 7px;border-radius:4px;background:rgba(255,255,255,.06);color:var(--dim)}
.z-cost{font-size:11px;font-weight:700;color:var(--gold);display:inline-block;padding:4px 12px;border-radius:6px;background:rgba(201,162,39,.09);border:1px solid var(--bdrB)}
.z-lock-hint{font-size:10px;color:var(--apex);margin-top:6px}

/* Trial stages */
.trial-stages{display:flex;flex-direction:column;gap:6px;margin-bottom:10px}
.trial-stage{display:flex;align-items:center;gap:10px;background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.18);border-radius:8px;padding:9px 11px;cursor:pointer;transition:all .2s}
.trial-stage:hover{background:rgba(239,68,68,.12)}
.trial-stage.cleared{border-color:rgba(201,162,39,.4);background:rgba(201,162,39,.05)}
.trial-stage.locked{opacity:.4;cursor:not-allowed}
.ts-ico{font-size:22px;flex-shrink:0}
.ts-info{flex:1}
.ts-name{font-size:12px;font-weight:700;color:#fca5a5}
.ts-desc{font-size:10px;color:var(--dim);margin-top:2px}
.ts-rew{font-size:10px;color:var(--gold);margin-top:2px}
.ts-badge{font-size:10px;padding:3px 9px;border-radius:6px;flex-shrink:0}
.ts-badge.clear{background:rgba(201,162,39,.15);border:1px solid var(--bdrB);color:var(--gl)}
.ts-badge.go{background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.4);color:#fca5a5}
.ts-badge.locked{background:rgba(255,255,255,.05);border:1px solid var(--bdr);color:var(--dim)}

/* Recent rings */
.ring-item{display:flex;align-items:center;gap:8px;background:var(--bgc);border:1px solid var(--bdr);border-radius:8px;padding:8px 10px;margin-bottom:6px}
.ring-orb{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:rgba(0,0,0,.7);flex-shrink:0}
.ring-yr{font-weight:700;font-size:12px}
.ring-sk{font-size:10px;color:var(--dim);margin-top:1px}
.ring-pow{font-size:9px;color:var(--gold);margin-top:1px}

/* LOTTERY PAGE V2 вАФ swipe banner */
/* Banner outer */
.lot-banner-outer{position:relative;margin:10px 0 0;height:calc(48vh - 56px);min-height:220px;max-height:295px;overflow:hidden}
.lot-banner-track{display:flex;width:300%;height:100%;transition:transform .38s cubic-bezier(.4,0,.2,1);will-change:transform}
.lot-slide{width:33.333%;height:100%;flex-shrink:0;position:relative;overflow:hidden}
.ls-0{background:linear-gradient(160deg,#06080f,#0c1020,#060810)}
.ls-1{background:linear-gradient(160deg,#0d0618,#160c30,#060210)}
.ls-2{background:linear-gradient(160deg,#140400,#250a00,#0a0200)}
.lot-geo-cvs{position:absolute;inset:0;pointer-events:none;z-index:1}
.lot-inner{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;justify-content:space-between;padding:15px 15px 13px}
.lot-top{display:flex;align-items:flex-start;justify-content:space-between}
.lot-ey{font-size:8px;color:rgba(255,255,255,.28);letter-spacing:2.5px;text-transform:uppercase;margin-bottom:4px}
.lot-nm{font-family:'Ma Shan Zheng',serif;font-size:24px;letter-spacing:3px;color:#fff;line-height:1.1}
.lot-sb{font-size:10px;color:rgba(255,255,255,.3);margin-top:3px}
.lot-cnt-n{font-size:28px;font-weight:700;line-height:1;margin-bottom:2px}
.lot-cnt-l{font-size:8px;color:rgba(255,255,255,.2)}
.lot-feat{background:rgba(0,0,0,.42);border:1px solid rgba(255,255,255,.08);border-radius:13px;padding:10px 12px;backdrop-filter:blur(8px);display:flex;align-items:center;gap:11px}
.lf-ico{font-size:32px;flex-shrink:0}
.lf-body{flex:1}
.lf-tag{font-size:8px;letter-spacing:1.5px;font-weight:700;margin-bottom:2px}
.lf-nm{font-size:13px;font-weight:700;color:#fff;margin-bottom:1px}
.lf-rate{font-size:9px;color:rgba(255,255,255,.3)}
.lf-badge{flex-shrink:0;padding:4px 10px;border-radius:7px;font-size:11px;font-weight:700;border:1px solid;backdrop-filter:blur(4px)}
.lot-ltd{position:absolute;top:12px;right:12px;z-index:3;background:rgba(239,68,68,.82);color:#fff;font-size:7px;font-weight:700;padding:3px 8px;border-radius:5px;letter-spacing:.8px;box-shadow:0 2px 8px rgba(239,68,68,.4)}
/* Dots */
.lot-dots{display:flex;justify-content:center;align-items:center;gap:6px;padding:7px 0 0}
.ldot{width:20px;height:3px;border-radius:2px;background:rgba(255,255,255,.14);cursor:pointer;transition:all .3s}
.ldot.active{width:28px;background:var(--lpc,#9ca3af);box-shadow:0 0 6px var(--lpc,#9ca3af)}
/* Pity */

/* Unified draw panel */
.lot-panel{margin:8px 11px 0;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.055);border-radius:16px;padding:13px;position:relative;overflow:hidden}
.lot-panel::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,var(--lpc-wash,transparent),transparent 70%);pointer-events:none;transition:background .5s}
/* Ticket row */

.lot-tp:active{transform:scale(.96)}
.lot-tp.c0{border-color:rgba(156,163,175,.2);background:rgba(156,163,175,.04)}
.lot-tp.c1{border-color:rgba(167,139,250,.22);background:rgba(167,139,250,.05)}
.lot-tp.c2{border-color:rgba(245,158,11,.22);background:rgba(245,158,11,.05)}
.lot-tp::before{content:'';position:absolute;top:0;left:-80%;width:45%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.05),transparent);animation:ltpShine var(--sd,4s) ease infinite}
@keyframes ltpShine{0%{left:-80%}100%{left:130%}}

.lot-tp.c0 
.lot-tp.c1 
.lot-tp.c2 

.lot-tp.c0 
.lot-tp.c1 
.lot-tp.c2 

/* SP divider */

/* Draw buttons */

/* Ten pull */
.lot-ten{border-radius:12px;padding:12px 14px;border:1.5px solid rgba(239,68,68,.55);background:linear-gradient(135deg,rgba(239,68,68,.1),rgba(245,158,11,.07),rgba(139,92,246,.05));cursor:pointer;transition:all .2s;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:space-between;box-shadow:0 0 16px rgba(239,68,68,.12),inset 0 1px 0 rgba(255,255,255,.06)}
.lot-ten:hover{border-color:rgba(239,68,68,.75);box-shadow:0 0 22px rgba(239,68,68,.2),inset 0 1px 0 rgba(255,255,255,.08)}
.lot-ten:active{transform:scale(.97);box-shadow:0 0 8px rgba(239,68,68,.15)}
.lt-left{display:flex;align-items:center;gap:10px}
.lt-ico{font-size:22px;filter:drop-shadow(0 0 6px rgba(245,158,11,.5))}
.lt-name{font-family:'Ma Shan Zheng',serif;font-size:14px;color:var(--gl);letter-spacing:2px}
.lt-sub{font-size:8px;color:rgba(239,68,68,.65);margin-top:2px}
.lt-cost{font-size:12px;font-weight:700;color:var(--gl)}
.lot-ten::before{content:'';position:absolute;top:0;left:-90%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.05),transparent);animation:ltShine 2.8s ease infinite}
@keyframes ltShine{0%{left:-90%}100%{left:130%}}
/* Rates */
.lot-rates{margin:8px 11px 0;border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,.05)}
.lr-head{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;cursor:pointer;background:rgba(255,255,255,.02)}
.lr-ttl{font-size:10px;color:rgba(255,255,255,.3);letter-spacing:.5px}
.lr-tog{font-size:9px;color:var(--dim)}
.lr-body{display:none;padding:6px 12px 10px;background:rgba(0,0,0,.15)}
.lr-row{display:flex;align-items:center;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.03);font-size:10px}
.lr-row:last-child{border:none}
.lr-item{display:flex;align-items:center;gap:6px;color:var(--txt)}
.lr-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.lr-pct{color:rgba(201,162,39,.8);font-weight:600}
.lr-lim{font-size:8px;color:#ef4444;margin-right:3px}
/* History */
.lot-hist-wrap{margin:8px 11px 0}
.lhw-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:7px}
.lhw-ttl{font-size:11px;font-weight:700;color:rgba(255,255,255,.55);display:flex;align-items:center;gap:5px}
.lhw-ttl::before{content:'';width:2px;height:10px;background:var(--gl);border-radius:2px;opacity:.55}
.lhw-tot{font-size:10px;color:var(--dim)}
.lh-item{display:flex;align-items:center;gap:9px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.04);border-radius:10px;padding:8px 10px;margin-bottom:5px}
.lh-item.leg{border-color:rgba(245,158,11,.18);background:rgba(245,158,11,.03)}
.lh-item.cos{border-color:rgba(0,255,255,.2);background:rgba(0,255,255,.03)}
.lh-n{flex-shrink:0;width:26px;height:26px;border-radius:7px;background:rgba(201,162,39,.07);border:1px solid var(--bdr);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--gl)}
.lh-b{flex:1;min-width:0}
.lh-items{font-size:10px;color:var(--txt);line-height:1.6;word-break:break-all}
.lh-meta{font-size:8px;color:var(--dim);margin-top:2px;display:flex;align-items:center;gap:5px;flex-wrap:wrap}
.lh-tag{font-size:8px;padding:1px 5px;border-radius:3px}
.lh-tk{background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.2);color:#60a5fa}
.lh-lg{background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.2);color:#f59e0b}
.lh-cs{background:rgba(0,255,255,.1);border:1px solid rgba(0,255,255,.25);color:#00ffff}
/* keep old pi for compat */
.pi{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid rgba(255,255,255,.03);font-size:10px}
.pi:last-child{border:none}
.pi-l{color:var(--txt)}
.pi-r{color:var(--gold)}
.pi-lim{color:#f87171;font-size:9px;margin-right:4px}

/* TASKS PAGE */
/* вФАвФА Tasks page v7 вФАвФА */
/* Cultivate widget */
.cult-widget{position:relative;margin:0 11px 9px;border-radius:16px;overflow:hidden;background:linear-gradient(135deg,rgba(16,185,129,.07),rgba(16,185,129,.025));border:1px solid rgba(16,185,129,.18)}
.cw-geo{position:absolute;inset:0;pointer-events:none;z-index:0}
.cw-body{position:relative;z-index:1;padding:13px}
.cw-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:11px}
.cw-title{font-family:'Ma Shan Zheng',serif;font-size:14px;color:#6ee7b7;letter-spacing:2px;display:flex;align-items:center;gap:7px}
.cw-title::before{content:'';width:3px;height:12px;background:#10b981;border-radius:2px;opacity:.7}
.cw-income{font-size:9px;color:rgba(16,185,129,.5);display:flex;gap:9px}
.cw-bars{display:flex;flex-direction:column;gap:7px;margin-bottom:12px}
.cw-bar-row{display:flex;align-items:center;gap:8px}
.cw-bar-lbl{font-size:9px;color:var(--dim);width:26px;flex-shrink:0}
.cw-bar-trk{flex:1;height:5px;background:rgba(255,255,255,.05);border-radius:3px;overflow:hidden}
.cw-bar-fill{height:100%;border-radius:3px;transition:width .5s ease;position:relative}
.cw-bar-fill::after{content:'';position:absolute;right:0;top:0;bottom:0;width:5px;background:rgba(255,255,255,.5);filter:blur(2px)}
.cw-bar-fill.cult-f{background:linear-gradient(90deg,rgba(16,185,129,.55),#10b981)}
.cw-bar-fill.expl-f{background:linear-gradient(90deg,rgba(59,130,246,.55),#3b82f6)}
.cw-bar-num{font-size:8px;color:var(--dim);width:54px;text-align:right;flex-shrink:0}
.cw-acts{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.cw-btn{border-radius:11px;padding:11px 8px;text-align:center;cursor:pointer;transition:all .2s;border:1px solid;position:relative;overflow:hidden}
.cw-btn:active{transform:scale(.95)}
.cw-btn.cult-b{border-color:rgba(16,185,129,.28);background:rgba(16,185,129,.06)}
.cw-btn.expl-b{border-color:rgba(59,130,246,.25);background:rgba(59,130,246,.05)}
.cw-btn.dis{opacity:.35;cursor:not-allowed;pointer-events:none}
.cw-btn-ico{font-size:20px;margin-bottom:4px}
.cw-btn-lbl{font-size:10px;font-weight:700;margin-bottom:2px}
.cw-btn.cult-b .cw-btn-lbl{color:#6ee7b7}
.cw-btn.expl-b .cw-btn-lbl{color:#93c5fd}
.cw-btn-cnt{font-size:9px;color:var(--dim)}
/* pbar compat */
.pbar{height:3px;background:rgba(255,255,255,.06);border-radius:2px;margin-top:4px}
.pfill{height:100%;background:linear-gradient(90deg,var(--gd),var(--gl));border-radius:2px;transition:width .5s ease}
/* Tasks section header */
.tasks-sh{display:flex;align-items:center;justify-content:space-between;padding:0 11px 8px}
.tasks-sh-title{font-size:10px;font-weight:700;color:rgba(255,255,255,.38);letter-spacing:.8px;text-transform:uppercase;display:flex;align-items:center;gap:5px}
.tasks-sh-title::before{content:'';width:2px;height:9px;background:var(--gl);border-radius:2px;opacity:.5}
.tasks-sh-right{display:flex;gap:6px;align-items:center}
.tasks-refresh-btn{font-size:9px;padding:3px 10px;border-radius:6px;border:1px solid var(--bdrB);color:var(--gl);cursor:pointer;background:rgba(201,162,39,.07);transition:all .2s}
.tasks-refresh-btn:active{transform:scale(.93)}
.tasks-refresh-btn.paid{border-color:rgba(239,68,68,.35);color:#f87171;background:rgba(239,68,68,.05)}
/* Task cards */
.tc{position:relative;margin:0 11px 7px;border-radius:13px;background:rgba(255,255,255,.022);border:1px solid rgba(255,255,255,.052);padding:12px 12px;overflow:hidden;cursor:default;transition:border-color .2s}
.tc.claimable{border-color:rgba(201,162,39,.3);background:rgba(201,162,39,.045)}
.tc.claimable::before{content:'';position:absolute;top:0;left:-80%;width:40%;height:100%;background:linear-gradient(90deg,transparent,rgba(201,162,39,.07),transparent);animation:tcShimmer 2.4s ease infinite}
@keyframes tcShimmer{0%{left:-80%}100%{left:130%}}
.tc.claimed{opacity:.42}
.tc.hidden{border-color:rgba(139,92,246,.22);background:rgba(139,92,246,.035)}
.tc-main{display:flex;align-items:center;gap:10px}
.tc-ico-w{width:38px;height:38px;border-radius:10px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:18px;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.065);transition:all .2s}
.tc.claimable .tc-ico-w{border-color:rgba(201,162,39,.25);background:rgba(201,162,39,.07)}
.tc.hidden .tc-ico-w{border-color:rgba(139,92,246,.22);background:rgba(139,92,246,.07)}
.tc-body{flex:1;min-width:0}
.tc-name{font-size:11px;font-weight:700;color:var(--txt);margin-bottom:2px}
.tc-desc{font-size:9px;color:var(--dim)}
.tc-right{flex-shrink:0;text-align:right}
.tc-rew{font-size:10px;font-weight:700;color:rgba(201,162,39,.8);margin-bottom:4px}
.tc-btn{font-size:9px;padding:4px 10px;border-radius:7px;border:1px solid;font-weight:700;white-space:nowrap;cursor:pointer;transition:all .2s;display:inline-block}
.tc-btn:active{transform:scale(.93)}
.tc-btn.do{border-color:rgba(201,162,39,.45);background:rgba(201,162,39,.12);color:var(--gl)}
.tc-btn.wait{border-color:rgba(255,255,255,.07);background:transparent;color:var(--dim);cursor:default;pointer-events:none}
.tc-btn.done{border-color:rgba(255,255,255,.06);background:transparent;color:var(--dim);cursor:default;pointer-events:none;opacity:.6}
.tc-pb{height:3px;background:rgba(255,255,255,.05);border-radius:2px;overflow:hidden;margin-top:6px}
.tc-pf{height:100%;border-radius:2px;transition:width .5s ease}
.tc.claimable .tc-pf,.tc-pf.done-f{background:linear-gradient(90deg,rgba(201,162,39,.7),var(--gl))}
.tc.hidden .tc-pf{background:linear-gradient(90deg,rgba(139,92,246,.7),#a78bfa)}
.tc-pf{background:linear-gradient(90deg,var(--gd),var(--gl))}
.tc-tix{display:inline-flex;align-items:center;gap:3px;font-size:8px;padding:2px 7px;border-radius:8px;margin-top:4px;border:1px solid rgba(255,255,255,.08);background:rgba(0,0,0,.18);color:rgba(255,255,255,.3)}
.tc.claimable .tc-tix{border-color:rgba(201,162,39,.3);color:var(--gl)}
.tc.hidden .tc-tix{border-color:rgba(139,92,246,.28);color:#a78bfa}
/* cult compat stubs for updateCultUI */
.cult-btn{display:none}.cb-ico{display:none}.cb-lbl{display:none}.cb-cnt{display:none}
.task-item{display:none}.ti-ico{display:none}.ti-body{display:none}
.ti-name{display:none}.ti-prog{display:none}.ti-rew{display:none}
.tclaim{display:none}

/* BAG PAGE */
.bag-tabs{display:flex;gap:4px;margin-bottom:10px;overflow-x:auto}
.bag-tabs::-webkit-scrollbar{display:none}
.btab{flex-shrink:0;padding:3px 11px;border-radius:20px;border:1px solid var(--bdr);font-size:10px;color:var(--dim);cursor:pointer;transition:all .2s;white-space:nowrap}
.btab.active{border-color:var(--bdrB);color:var(--gl);background:rgba(201,162,39,.1)}
.bag-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px}
.bag-item{aspect-ratio:1;border-radius:8px;background:var(--bgc);border:1px solid var(--bdr);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;position:relative;padding:3px}
.bag-item:active{transform:scale(.96)}
.bag-item .bi{font-size:22px}
.bag-item .bn{font-size:8px;color:var(--dim);margin-top:2px;text-align:center;line-height:1.2}
.bag-item .bc{position:absolute;top:2px;right:2px;font-size:8px;font-weight:700;color:var(--gl);background:rgba(0,0,0,.5);border-radius:3px;padding:1px 3px}

/* MODAL */
#modal{position:fixed;inset:0;z-index:280;background:rgba(0,0,0,.86);display:none;align-items:flex-end;justify-content:center}
#modal.show{display:flex}
.msheet{width:100%;max-width:430px;background:linear-gradient(180deg,#0e1525,#080d1a);border-top:1px solid var(--bdr);border-radius:18px 18px 0 0;padding:16px;max-height:82vh;overflow-y:auto;animation:sUp .28s ease}
@keyframes sUp{from{transform:translateY(100%);opacity:0}to{transform:translateY(0);opacity:1}}
.msheet::-webkit-scrollbar{display:none}
.mh{width:34px;height:3px;border-radius:2px;background:rgba(255,255,255,.1);margin:0 auto 13px}
.m-title{font-family:'Ma Shan Zheng',serif;font-size:19px;text-align:center;margin-bottom:2px}
.m-sub{text-align:center;font-size:10px;color:var(--dim);margin-bottom:12px}
.m-sec{margin-bottom:11px}
.m-sec-t{font-size:10px;color:var(--dim);display:flex;align-items:center;gap:5px;margin-bottom:6px}
.m-sec-t::before,.m-sec-t::after{content:'';flex:1;height:1px;background:var(--bdr)}
.m-ag{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.m-at{background:rgba(201,162,39,.04);border:1px solid var(--bdr);border-radius:6px;padding:6px 8px}
.m-an{font-size:9px;color:var(--dim)}
.m-av{font-size:13px;font-weight:700;color:var(--gl)}
.m-acts{display:flex;gap:6px;margin-top:11px}
.m-btn{flex:1;padding:10px;border-radius:8px;text-align:center;font-size:11px;font-weight:700;cursor:pointer;border:1px solid var(--bdr);transition:all .2s}
.m-btn:active{transform:scale(.97)}
.m-btn.ok{background:rgba(201,162,39,.13);border-color:var(--bdrB);color:var(--gl)}
.m-btn.bad{background:rgba(220,38,38,.07);border-color:rgba(220,38,38,.28);color:#f87171}
.m-btn.grn{background:rgba(16,185,129,.07);border-color:rgba(16,185,129,.28);color:#6ee7b7}
.m-btn.blue{background:rgba(59,130,246,.07);border-color:rgba(59,130,246,.28);color:#93c5fd}

/* FUSION PAGE */
#PF{display:none;padding:11px}
#PF.active{display:block}
.back-btn{display:flex;align-items:center;gap:4px;font-size:12px;color:var(--dim);cursor:pointer;margin-bottom:10px;padding:3px 0}
.back-btn:hover{color:var(--gl)}
.fus-circles{display:flex;align-items:center;justify-content:center;gap:12px;margin:14px 0}
.f-c{width:76px;height:76px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;border:1px solid var(--bdrB);background:radial-gradient(ellipse,rgba(18,26,50,.95),#050810);font-size:9px;color:var(--dim);cursor:pointer;transition:all .2s;position:relative}
.f-c.filled{border-color:var(--gold);background:rgba(201,162,39,.07)}
.f-c.result{width:86px;height:86px}
.f-plus{font-size:20px;color:var(--dim)}
.fh-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:7px}
.fhs{width:48px;height:48px;border-radius:8px;border:1px solid var(--bdr);background:var(--bgc);display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:18px;cursor:pointer;transition:all .2s;position:relative}
.fhs:hover{border-color:rgba(34,197,94,.38)}
.fhs.filled{border-color:rgba(34,197,94,.48);background:rgba(34,197,94,.05)}
.fhs-rm{position:absolute;top:-4px;right:-4px;width:14px;height:14px;border-radius:50%;background:rgba(220,38,38,.85);font-size:8px;display:flex;align-items:center;justify-content:center;color:#fff;cursor:pointer}
.fr-row{display:flex;justify-content:space-between;font-size:11px;padding:3px 0}
.fr-l{color:var(--dim)}.fr-v{color:var(--gl);font-weight:600}
.fus-btn{width:100%;padding:13px;border-radius:10px;border:1px solid var(--bdrB);background:linear-gradient(135deg,rgba(201,162,39,.18),rgba(201,162,39,.05));color:var(--gl);font-family:'Ma Shan Zheng',serif;font-size:17px;letter-spacing:4px;cursor:pointer;transition:all .3s}
.fus-btn:hover{box-shadow:0 0 16px rgba(201,162,39,.3)}
.fus-btn:disabled{opacity:.38;cursor:not-allowed}

/* PATH GRID */
.path-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.pcard{border-radius:10px;padding:11px;border:1px solid var(--bdr);cursor:pointer;transition:all .2s;background:var(--bgc)}
.pcard:hover{border-color:var(--bdrB)}
.pc-i{font-size:24px;margin-bottom:4px}
.pc-n{font-family:'Ma Shan Zheng',serif;font-size:12px;color:var(--gl);margin-bottom:2px}
.pc-d{font-size:9px;color:var(--dim);line-height:1.4}
.pc-r{font-size:9px;color:var(--apex);margin-top:3px}

/* MISC */
.empty-st{text-align:center;padding:30px 14px;color:var(--dim)}
.empty-st .ei{font-size:40px;margin-bottom:8px}
.empty-st .em{font-size:12px}
.btn{padding:8px 14px;border-radius:8px;border:1px solid var(--bdrB);background:rgba(201,162,39,.1);color:var(--gl);font-size:11px;font-weight:700;cursor:pointer;transition:all .2s}
.btn:active{transform:scale(.97)}
.btn.sm{padding:5px 10px;font-size:10px}
.btn.red{background:rgba(220,38,38,.08);border-color:rgba(220,38,38,.25);color:#f87171}

/* вФАвФА Shared utility classes (v5.2) вФАвФА */
/* Toggle button shared style */
.tog-btn{font-size:10px;color:var(--dim);cursor:pointer;padding:2px 8px;border-radius:4px;background:rgba(255,255,255,.05);flex-shrink:0}
/* Ticket action buttons (used in modal) */
.t-btn{padding:6px 12px;border-radius:7px;font-size:11px;font-weight:700;cursor:pointer;border:1px solid;text-align:center;transition:opacity .2s;white-space:nowrap;flex:1}
.t-btn:active{opacity:.7}
.t-btn-ok{border-color:var(--bdrB);background:rgba(201,162,39,.12);color:var(--gl)}
.t-btn-ten{border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.1);color:#fca5a5}
.t-btn-bad{border-color:rgba(220,38,38,.25);background:rgba(220,38,38,.05);color:#f87171}

/* BAG FAB */
#bag-fab{transition:transform .2s,box-shadow .2s}
#bag-fab:active{transform:scale(.92)}
#bag-fab.open{background:linear-gradient(135deg,rgba(239,68,68,.25),rgba(201,162,39,.1));border-color:rgba(239,68,68,.5);box-shadow:0 0 16px rgba(239,68,68,.3)}
/* WORLD PAGE CARDS */
.world-card-big{border-radius:16px;overflow:hidden;position:relative;cursor:pointer;transition:transform .15s;min-height:200px;display:flex;flex-direction:column;justify-content:flex-end}
.world-card-big:active{transform:scale(.98)}
.world-card-big.locked{opacity:.55;cursor:not-allowed;filter:grayscale(.5)}
.wc-bg{position:absolute;inset:0;z-index:0}
.wc-body{position:relative;z-index:1;padding:16px}
.wc-icon{font-size:52px;text-align:center;margin-bottom:10px}
.wc-title{font-family:'Ma Shan Zheng',serif;font-size:22px;letter-spacing:3px;margin-bottom:4px}
.wc-sub{font-size:11px;opacity:.7;margin-bottom:10px;line-height:1.6}
.wc-tags{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:12px}
.wc-tag{font-size:9px;padding:2px 8px;border-radius:4px;background:rgba(0,0,0,.4)}
.wc-footer{display:flex;align-items:center;justify-content:space-between}
.wc-prog{font-size:10px;opacity:.7}
/* Page dots */
.world-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.2);cursor:pointer;transition:all .2s}
.world-dot.active{background:var(--gl);width:20px;border-radius:4px}

/* SEASONAL TASK */
.seasonal-badge{display:inline-block;font-size:9px;padding:1px 7px;border-radius:10px;background:rgba(255,192,203,.12);border:1px solid rgba(255,192,203,.3);color:#f9a8d4}

/* GOD BONE GLOW */
.bone-slot.god-filled{border-color:rgba(255,215,0,.7)!important;background:rgba(255,215,0,.08)!important;box-shadow:0 0 10px rgba(255,215,0,.3)}

/* EXTREME ARTIFACT */

/* RESONANCE INDICATOR */
.resonance-glow{background:linear-gradient(135deg,rgba(255,215,0,.15),rgba(0,255,255,.1));border:1px solid rgba(255,215,0,.4);border-radius:8px;padding:6px 10px;margin-top:6px;font-size:10px;color:var(--gl);text-align:center}

/* LOT ANIMATION UPGRADE */
@keyframes lotCardPop{0%{opacity:0;transform:scale(.6) translateY(20px)}70%{transform:scale(1.08) translateY(-3px)}100%{opacity:1;transform:scale(1) translateY(0)}}
.lot-card-anim{animation:lotCardPop .5s cubic-bezier(.34,1.56,.64,1) both}
@keyframes prizeFlash{0%,100%{opacity:1}50%{opacity:.4}}
.prize-flash{animation:prizeFlash .3s ease 3}

/* TITLE EQUIPPED */
.title-equipped{background:rgba(201,162,39,.18)!important;box-shadow:0 0 6px rgba(201,162,39,.4)}

/* GM MODE */
#gm-panel{position:fixed;inset:0;z-index:600;background:rgba(0,0,0,.97);display:none;flex-direction:column;overflow:hidden}
#gm-panel.show{display:flex}
.gm-t{font-size:11px;color:var(--dim);letter-spacing:.5px;padding:2px 0 6px}
.gm-row{display:flex;gap:7px;margin-bottom:8px;flex-wrap:wrap}
.gm-btn{padding:8px 12px;border-radius:8px;border:1px solid;font-size:11px;font-weight:700;cursor:pointer;text-align:center;transition:all .2s;flex-shrink:0}
.gm-btn:active{opacity:.7}
.gm-btn-g{border-color:var(--bdrB);background:rgba(201,162,39,.15);color:var(--gl)}
.gm-btn-r{border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.1);color:#fca5a5}
.gm-btn-b{border-color:rgba(59,130,246,.4);background:rgba(59,130,246,.1);color:#93c5fd}
.gm-btn-p{border-color:rgba(139,92,246,.4);background:rgba(139,92,246,.1);color:#c4b5fd}
.gm-inp{background:rgba(255,255,255,.06);border:1px solid var(--bdr);border-radius:7px;padding:7px 10px;font-size:12px;color:var(--txt);width:100%;margin-bottom:7px}
.gm-inp:focus{outline:none;border-color:var(--bdrB)}

/* вХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХР
   SOUL PAGE V2 вАФ layout, orbit, sections
вХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХР */
#page-soul{padding:0}
#page-lottery{padding:0}
#soul-geo-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:0;transition:opacity .8s}
#soul-geo-canvas.visible{opacity:1}

.soul-v2-hero{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;padding:22px 16px 6px}

/* Orbit ring system */
.soul-orbit{position:relative;width:190px;height:190px;display:flex;align-items:center;justify-content:center;margin-bottom:16px}
.sol-ring{position:absolute;border-radius:50%;border:1px solid var(--qc,#f59e0b)}
.sol-ring.r1{width:160px;height:160px;opacity:.18;animation:solSpin 14s linear infinite}
.sol-ring.r2{width:180px;height:180px;opacity:.09;animation:solSpin 26s linear infinite reverse}
.sol-ring.r3{width:198px;height:198px;opacity:.05;border-style:dashed;animation:solSpin 38s linear infinite}
@keyframes solSpin{to{transform:rotate(360deg)}}
.sol-dot{position:absolute;width:5px;height:5px;border-radius:50%;background:var(--qc,#f59e0b);box-shadow:0 0 6px var(--qc,#f59e0b),0 0 14px var(--qc,#f59e0b);top:50%;left:50%;animation:solDotOrbit 14s linear infinite}
@keyframes solDotOrbit{
  0%{transform:rotate(var(--s,0deg)) translateX(80px) translateY(-2.5px)}
  100%{transform:rotate(calc(var(--s,0deg) + 360deg)) translateX(80px) translateY(-2.5px)}
}
.sol-dot.s2{width:3px;height:3px;opacity:.65;animation:solDotOrbit2 23s linear infinite reverse}
@keyframes solDotOrbit2{
  0%{transform:rotate(var(--s,0deg)) translateX(90px) translateY(-1.5px)}
  100%{transform:rotate(calc(var(--s,0deg) + 360deg)) translateX(90px) translateY(-1.5px)}
}
.sol-glow{position:absolute;width:128px;height:128px;border-radius:50%;filter:blur(12px);animation:solGlowPulse 3.2s ease infinite}
@keyframes solGlowPulse{0%,100%{opacity:.55;transform:scale(1)}50%{opacity:1;transform:scale(1.15)}}
.sol-icon{position:relative;z-index:2;font-size:82px;line-height:1;animation:solIconFloat 3.5s ease infinite}
@keyframes solIconFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}

/* Identity */
.sol-name{font-family:'Ma Shan Zheng',serif;font-size:28px;letter-spacing:4px;text-align:center;line-height:1.2;margin-bottom:6px}
.sol-meta{display:flex;align-items:center;justify-content:center;gap:7px;flex-wrap:wrap;margin-bottom:7px}
.sol-quality-tag{display:inline-flex;align-items:center;gap:5px;font-size:9px;font-weight:700;letter-spacing:1.5px;padding:3px 11px 3px 8px;border-radius:20px;border:1px solid;position:relative;overflow:hidden}
.sol-quality-tag::before{content:'';position:absolute;inset:0;background:inherit;opacity:.12;border-radius:20px}
.sol-qt-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;animation:qtDotPulse 2.4s ease infinite}
@keyframes qtDotPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.55;transform:scale(.75)}}
.sol-rank{font-size:10px;color:var(--dim)}
.sol-sep{width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,.12)}
.sol-title{display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.07);border-radius:6px;padding:4px 12px;cursor:pointer;transition:border-color .2s;margin-bottom:10px}
.sol-title:hover{border-color:var(--qc,#f59e0b)}
.sol-title-star{font-size:10px}
.sol-title-name{font-size:10px;color:var(--txt);letter-spacing:.8px}
.sol-title-change{font-size:9px;color:var(--dim)}
.sol-attrs{display:flex;gap:5px;flex-wrap:wrap;justify-content:center;padding:0 16px;margin-bottom:12px}
.sol-attr{font-size:9px;padding:2px 8px;border-radius:4px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);color:rgba(255,255,255,.4)}

/* Quick actions вАФ 4 buttons */
.sol-actions{display:flex;gap:7px;width:100%;padding:0 11px;margin-bottom:6px}
.sol-act{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:9px 4px 8px;border-radius:11px;cursor:pointer;border:1px solid rgba(255,255,255,.07);background:rgba(255,255,255,.03);transition:all .18s}
.sol-act:active{transform:scale(.93)}
.sol-act.hi{border-color:var(--qc-border,rgba(245,158,11,.28));background:var(--qc-bg,rgba(245,158,11,.06))}
.sol-act-ico{font-size:18px}
.sol-act-lbl{font-size:8px;color:var(--dim);text-align:center;line-height:1.3}
.sol-act.hi .sol-act-lbl{color:var(--soul-col,var(--gl));opacity:.85}

/* EXP strip */
.sol-exp-row{width:100%;padding:0 11px;margin-bottom:4px}
.sol-exp-meta{display:flex;justify-content:space-between;font-size:9px;color:var(--dim);margin-bottom:3px}
.sol-exp-bar{width:100%;height:3px;background:rgba(255,255,255,.05);border-radius:2px;overflow:hidden}
.sol-exp-fill{height:100%;background:linear-gradient(90deg,var(--gd),var(--gl));border-radius:2px;transition:width .6s ease}

/* Section cards */
.sv2-card{background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.055);border-radius:13px;padding:12px 13px;margin:0 11px 8px;position:relative;z-index:1}
.sv2-card.accent{border-color:var(--qc-border,rgba(245,158,11,.18));background:var(--qc-bg2,rgba(245,158,11,.04))}
.sv2-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px}
.sv2-title{font-size:10px;font-weight:700;color:rgba(255,255,255,.4);letter-spacing:.8px;text-transform:uppercase;display:flex;align-items:center;gap:5px}
.sv2-title::before{content:'';width:2px;height:9px;background:var(--soul-col,var(--gl));border-radius:2px;opacity:.7}
.sv2-action{font-size:9px;color:var(--dim);cursor:pointer}

/* Ring arc */
.sv2-ring-arc{position:relative;height:50px;margin-bottom:9px;overflow:visible}
.sv2-r-orb{position:absolute;width:28px;height:28px;border-radius:50%;bottom:0;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:rgba(0,0,0,.75);border:1.5px solid var(--rc,#a78bfa);background:radial-gradient(ellipse at 35% 30%,var(--rc,#a78bfa),rgba(0,0,0,.85));box-shadow:0 2px 6px rgba(0,0,0,.4),0 0 5px var(--rc,#a78bfa);cursor:pointer;transition:transform .2s}
.sv2-r-orb:hover{transform:scale(1.22) translateY(-4px) !important}
.sv2-r-orb.empty{background:rgba(255,255,255,.03);border:1px dashed rgba(255,255,255,.1);box-shadow:none;color:rgba(255,255,255,.15);font-size:11px}
.sv2-rl{display:flex;flex-direction:column;gap:3px}
.sv2-rl-row{display:flex;align-items:center;gap:6px;padding:4px 6px;border-radius:6px;background:rgba(255,255,255,.02)}
.sv2-rl-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.sv2-rl-name{font-size:10px;color:var(--txt);flex:1}
.sv2-rl-tier{font-size:9px;color:var(--dim)}
.sv2-rl-pw{font-size:9px;color:rgba(201,162,39,.7);font-weight:600}
.sv2-rl-more{text-align:center;font-size:9px;color:var(--dim);padding:5px 0 1px;cursor:pointer}

/* Gear 2-col */
.sv2-gear{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:0 11px 8px;position:relative;z-index:1}
.sv2-gcol{background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.055);border-radius:13px;padding:11px}
.sv2-gc-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.sv2-gc-title{font-size:9px;font-weight:700;color:rgba(255,255,255,.35);letter-spacing:.8px;text-transform:uppercase}
.sv2-gc-action{font-size:9px;color:var(--dim);cursor:pointer}
.sv2-bone-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px}
.sv2-b-slot{aspect-ratio:1;border-radius:7px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:13px;cursor:pointer;position:relative;transition:all .18s}
.sv2-b-slot.on{border-color:rgba(251,191,36,.28);background:rgba(251,191,36,.05)}
.sv2-b-slot.on::after{content:'';position:absolute;top:2px;right:3px;width:4px;height:4px;border-radius:50%;background:var(--soul-col,var(--gl))}
.sv2-b-pw{font-size:6px;color:rgba(255,255,255,.25);margin-top:1px}
.sv2-b-slot.on .sv2-b-pw{color:rgba(251,191,36,.55)}
.sv2-bone-sum{font-size:8px;color:var(--dim);text-align:center;margin-top:6px}
.sv2-art{display:flex;flex-direction:column;align-items:center;text-align:center}
.sv2-art-wrap{width:50px;height:50px;border-radius:11px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);display:flex;align-items:center;justify-content:center;font-size:26px;margin-bottom:6px}
.sv2-art-wrap.eq{border-color:var(--qc-border,rgba(245,158,11,.3));box-shadow:0 0 12px var(--soul-glow,rgba(245,158,11,.3))}
.sv2-art-name{font-size:10px;font-weight:700;color:rgba(245,158,11,.85)}
.sv2-art-pw{font-size:8px;color:rgba(255,255,255,.25);margin-top:1px}
.sv2-art-bonus{font-size:8px;color:var(--dim);margin-top:2px;line-height:1.5}
.sv2-art-none{text-align:center;padding:10px 0;color:var(--dim);font-size:10px}

/* Skills */
.sv2-sk{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.03)}
.sv2-sk:last-child{border:none;padding-bottom:1px}
.sv2-sk-ico{width:28px;height:28px;border-radius:7px;flex-shrink:0;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.18);display:flex;align-items:center;justify-content:center;font-size:13px}
.sv2-sk-body{flex:1;min-width:0}
.sv2-sk-name{font-size:11px;font-weight:600;color:rgba(196,181,253,.85)}
.sv2-sk-desc{font-size:9px;color:var(--dim);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px}
.sv2-sk-ring{flex-shrink:0;font-size:8px;padding:1px 5px;border-radius:3px;background:rgba(124,58,237,.1);color:rgba(167,139,250,.65)}

/* God banner + resonance */
.sv2-god-banner{margin:0 11px 8px;padding:10px 13px;border-radius:12px;display:flex;align-items:center;gap:10px;position:relative;z-index:1}
.sv2-god-ico{font-size:26px}
.sv2-god-name{font-family:'Ma Shan Zheng',serif;font-size:14px;letter-spacing:2px}
.sv2-god-sub{font-size:9px;opacity:.6;margin-top:2px}
.sv2-resonance{margin:0 11px 8px;padding:8px 12px;border-radius:9px;background:linear-gradient(135deg,rgba(255,215,0,.1),rgba(0,255,255,.07));border:1px solid rgba(255,215,0,.28);font-size:10px;color:var(--gl);text-align:center;position:relative;z-index:1}
.sv2-reset{margin:0 11px 8px;padding:9px;border-radius:9px;text-align:center;border:1px solid rgba(220,38,38,.13);background:rgba(220,38,38,.03);color:rgba(248,113,113,.4);font-size:10px;cursor:pointer;position:relative;z-index:1}

/* Merged draw grid (v7.1) */
.lot-draw-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:7px}
.lot-dg-btn{
  border-radius:12px;padding:12px 10px;
  border:1px solid rgba(255,255,255,.07);background:rgba(255,255,255,.03);
  cursor:pointer;transition:all .2s;position:relative;overflow:hidden;
}
.lot-dg-btn:active{transform:scale(.95)}
.lot-dg-btn.has-tix{border-color:rgba(var(--lpc-r,201),var(--lpc-g,162),var(--lpc-b,39),.28);background:rgba(var(--lpc-r,201),var(--lpc-g,162),var(--lpc-b,39),.05)}
.ldg-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.ldg-ico{font-size:18px}
.ldg-tix-badge{
  font-size:8px;font-weight:700;padding:2px 6px;border-radius:10px;
  border:1px solid;white-space:nowrap;
  background:rgba(0,0,0,.3);
}
.ldg-lbl{font-size:11px;font-weight:700;color:var(--txt);margin-bottom:2px}
.ldg-cost{font-size:9px;color:rgba(201,162,39,.65)}
.ldg-tix-action{font-size:8px;margin-top:3px;opacity:.7}
/* Ten-pull ticket note */
.lt-tix-note{font-size:8px;color:rgba(255,255,255,.4);margin-top:2px;text-align:right;min-height:12px}

/* вФАвФА Seasonal Banner v7 вФАвФА */
.sb-banner{position:relative;margin:10px 11px 8px;border-radius:16px;overflow:hidden;cursor:pointer;background:linear-gradient(135deg,rgba(255,192,203,.08),rgba(201,162,39,.05),rgba(255,192,203,.04));border:1px solid rgba(255,192,203,.25);transition:border-color .3s}
.sb-banner:hover{border-color:rgba(255,192,203,.45)}
.sb-banner:active{transform:scale(.99)}
.sb-geo{position:absolute;inset:0;pointer-events:none;z-index:0}
.sb-body{position:relative;z-index:1;display:flex;align-items:center;gap:12px;padding:13px 14px}
.sb-left{flex:1;min-width:0}
.sb-tag-row{display:flex;align-items:center;gap:6px;margin-bottom:5px}
.sb-dot{width:6px;height:6px;border-radius:50%;background:#f9a8d4;flex-shrink:0;animation:sbDotPulse 2s ease infinite}
@keyframes sbDotPulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(249,168,212,.6)}50%{opacity:.5;box-shadow:0 0 0 5px rgba(249,168,212,0)}}
.sb-tag-lbl{font-size:8px;color:#f9a8d4;letter-spacing:2px;font-weight:700;text-transform:uppercase}
.sb-tag-badge{font-size:8px;color:rgba(239,68,68,.9);padding:1px 6px;border-radius:4px;background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);letter-spacing:.5px}
.sb-name{font-family:'Ma Shan Zheng',serif;font-size:18px;color:#fce7f3;letter-spacing:3px;margin-bottom:3px;text-shadow:0 0 12px rgba(249,168,212,.35)}
.sb-desc{font-size:9px;color:rgba(249,168,212,.5);line-height:1.6}
.sb-right{flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:4px}
.sb-ico{font-size:32px;filter:drop-shadow(0 0 10px rgba(249,168,212,.55));animation:sbIcoFloat 3s ease infinite}
@keyframes sbIcoFloat{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-4px) scale(1.06)}}
.sb-cnt{font-size:9px;color:rgba(249,168,212,.55);white-space:nowrap}
.sb-arrow{font-size:10px;color:rgba(249,168,212,.4);transition:transform .25s}
.sb-banner.open .sb-arrow{transform:rotate(180deg)}
/* detail panel */
.sb-detail{display:none;position:relative;z-index:1;padding:0 14px 12px}
.sb-banner.open .sb-detail{display:block}
.sb-divider{height:1px;background:linear-gradient(90deg,transparent,rgba(255,192,203,.2),transparent);margin-bottom:10px}
.sb-task-row{display:flex;align-items:center;gap:9px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.03)}
.sb-task-row:last-child{border:none}
.sb-task-ico{font-size:16px;flex-shrink:0;width:22px;text-align:center}
.sb-task-body{flex:1;min-width:0}
.sb-task-name{font-size:10px;font-weight:600;color:var(--txt);margin-bottom:1px}
.sb-task-desc{font-size:8px;color:var(--dim);line-height:1.5}
.sb-task-prog{font-size:8px;color:rgba(249,168,212,.6);margin-top:2px}
.sb-task-rew{flex-shrink:0;text-align:right}
.sb-task-cnt{font-size:11px;font-weight:700;color:#fca5a5}
.sb-task-lbl{font-size:7px;color:var(--dim)}

/* вХРвХР ж≠¶й≠ВеЫЊйЙі Sidebar вХРвХР */
.sv2-bottom-row{display:flex;gap:7px;margin:0 11px 8px;position:relative;z-index:1}
.sv2-grimoire-btn{
  flex:1;display:flex;align-items:center;justify-content:center;gap:6px;
  padding:10px 8px;border-radius:10px;cursor:pointer;transition:all .2s;
  border:1px solid rgba(139,92,246,.32);background:rgba(139,92,246,.07);
  color:#c4b5fd;font-size:10px;font-weight:700;letter-spacing:.5px;
}
.sv2-grimoire-btn:active{transform:scale(.95)}
.sv2-grimoire-btn .gb-ico{font-size:16px}
.sv2-reawaken-btn{
  flex:1;display:flex;align-items:center;justify-content:center;gap:5px;
  padding:10px 8px;border-radius:10px;cursor:pointer;transition:all .2s;
  border:1px solid rgba(220,38,38,.18);background:rgba(220,38,38,.04);
  color:rgba(248,113,113,.5);font-size:10px;font-weight:700;letter-spacing:.5px;
}
.sv2-reawaken-btn:active{transform:scale(.95)}

/* Sidebar overlay */
#grimoire-sidebar{
  position:fixed;inset:0;z-index:400;
  display:flex;pointer-events:none;
}
#grimoire-sidebar.open{pointer-events:all}
.gs-backdrop{
  position:absolute;inset:0;background:rgba(0,0,0,0);
  transition:background .32s ease;cursor:pointer;
}
#grimoire-sidebar.open .gs-backdrop{background:rgba(0,0,0,.75)}
.gs-panel{
  position:absolute;top:0;left:0;bottom:0;
  width:88%;max-width:360px;
  background:linear-gradient(180deg,#080e1e,#060b18);
  border-right:1px solid rgba(139,92,246,.22);
  display:flex;flex-direction:column;
  transform:translateX(-100%);
  transition:transform .32s cubic-bezier(.4,0,.2,1);
  box-shadow:4px 0 32px rgba(0,0,0,.65);
}
#grimoire-sidebar.open .gs-panel{transform:translateX(0)}

/* Sidebar header */
.gs-hd{
  flex-shrink:0;padding:16px 16px 13px;
  background:linear-gradient(180deg,rgba(139,92,246,.11),transparent);
  border-bottom:1px solid rgba(139,92,246,.14);
  position:relative;overflow:hidden;
}
.gs-hd-cvs{position:absolute;inset:0;pointer-events:none;z-index:0}
.gs-hd-inner{position:relative;z-index:1}
.gs-hd-tag{font-size:8px;color:rgba(139,92,246,.7);letter-spacing:2px;font-weight:700;text-transform:uppercase;margin-bottom:5px;display:flex;align-items:center;gap:5px}
.gs-hd-dot{width:5px;height:5px;border-radius:50%;background:#8b5cf6;animation:gsDot 2.2s ease infinite}
@keyframes gsDot{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(139,92,246,.6)}55%{opacity:.4;box-shadow:0 0 0 5px rgba(139,92,246,0)}}
.gs-hd-title{font-family:'Ma Shan Zheng',serif;font-size:22px;letter-spacing:4px;background:linear-gradient(135deg,#c4b5fd,#8b5cf6,#6d28d9);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:3px}
.gs-hd-sub{font-size:9px;color:var(--dim)}
.gs-stats{display:flex;gap:6px;margin-top:10px}
.gs-stat{flex:1;text-align:center;background:rgba(139,92,246,.07);border:1px solid rgba(139,92,246,.14);border-radius:8px;padding:6px 4px}
.gs-stat-v{font-size:16px;font-weight:700;color:#c4b5fd}
.gs-stat-l{font-size:8px;color:var(--dim);margin-top:1px}

/* Sidebar body */
.gs-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch}
.gs-body::-webkit-scrollbar{display:none}

/* Filters */
.gs-filters{display:flex;gap:5px;padding:10px 13px;flex-wrap:wrap;border-bottom:1px solid rgba(255,255,255,.04)}
.gf{padding:3px 10px;border-radius:16px;font-size:9px;font-weight:600;border:1px solid rgba(255,255,255,.08);color:var(--dim);cursor:pointer;transition:all .18s;letter-spacing:.4px}
.gf:active{transform:scale(.92)}
.gf.active{color:#fff;border-color:var(--gfc,rgba(255,255,255,.3));background:rgba(var(--gfr,255),var(--gfg,255),var(--gfb,255),.12);box-shadow:0 0 7px rgba(var(--gfr,255),var(--gfg,255),var(--gfb,255),.18)}

/* Search */
.gs-search{margin:9px 13px 4px;position:relative}
.gs-search-inp{width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:7px 13px 7px 32px;font-size:10px;color:var(--txt);outline:none;font-family:'Noto Sans SC',sans-serif}
.gs-search-inp::placeholder{color:var(--dim)}
.gs-search-inp:focus{border-color:rgba(139,92,246,.4);background:rgba(139,92,246,.04)}
.gs-search-ico{position:absolute;left:11px;top:50%;transform:translateY(-50%);font-size:12px;opacity:.38;pointer-events:none}

/* Grid */
.gs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;padding:10px 13px}
.gc{
  border-radius:12px;padding:10px 7px 9px;text-align:center;
  border:1px solid rgba(255,255,255,.055);background:rgba(255,255,255,.02);
  cursor:pointer;transition:all .2s;position:relative;overflow:hidden;
}
.gc:active{transform:scale(.94)}
.gc.found{border-color:var(--qbdr,rgba(255,255,255,.12));background:rgba(var(--qr,255),var(--qg,255),var(--qb,255),.04)}
.gc.found:hover{background:rgba(var(--qr,255),var(--qg,255),var(--qb,255),.08)}
.gc.unfound{filter:grayscale(1);opacity:.25;cursor:not-allowed}
.gc.found::before{content:'';position:absolute;top:0;left:-80%;width:40%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.04),transparent);animation:gcShimmer var(--sd,7s) ease infinite var(--dl,0s)}
@keyframes gcShimmer{0%{left:-80%}100%{left:130%}}
.gc-ico{font-size:26px;margin-bottom:5px;position:relative;z-index:1}
.gc-name{font-size:9px;font-weight:600;color:var(--txt);line-height:1.3;margin-bottom:3px;position:relative;z-index:1}
.gc.unfound .gc-name{color:var(--dim)}
.gc-q{font-size:7px;font-weight:700;letter-spacing:.8px;position:relative;z-index:1}
.gc-owned{position:absolute;top:4px;right:4px;width:14px;height:14px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:7px;color:#000;font-weight:900}

/* Soul detail bottom sheet */
.gs-detail{
  position:absolute;bottom:0;left:0;right:0;
  background:linear-gradient(180deg,#0c1428,#080e1c);
  border-top:1px solid rgba(139,92,246,.25);
  border-radius:16px 16px 0 0;
  padding:13px 15px 22px;
  transform:translateY(100%);
  transition:transform .3s cubic-bezier(.4,0,.2,1);
  z-index:10;max-height:68%;overflow-y:auto;
}
.gs-detail::-webkit-scrollbar{display:none}
.gs-detail.show{transform:translateY(0)}
.gs-d-handle{width:32px;height:3px;border-radius:2px;background:rgba(255,255,255,.1);margin:0 auto 11px}
.gs-d-top{display:flex;align-items:flex-start;gap:11px;margin-bottom:11px}
.gs-d-ico-wrap{position:relative;flex-shrink:0}
.gs-d-ico{font-size:50px;line-height:1;display:block}
.gs-d-glow{position:absolute;inset:-6px;border-radius:50%;background:radial-gradient(ellipse,var(--qglow,rgba(139,92,246,.3)),transparent 65%);animation:gdGlow 3s ease infinite}
@keyframes gdGlow{0%,100%{opacity:.55;transform:scale(1)}50%{opacity:1;transform:scale(1.14)}}
.gs-d-info{flex:1}
.gs-d-name{font-family:'Ma Shan Zheng',serif;font-size:19px;letter-spacing:2px;margin-bottom:4px}
.gs-d-qtag{display:inline-flex;align-items:center;gap:5px;padding:3px 10px 3px 7px;border-radius:20px;border:1px solid;font-size:9px;font-weight:700;letter-spacing:1px;margin-bottom:5px}
.gs-d-qdot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.gs-d-desc{font-size:10px;color:var(--dim);line-height:1.7}
.gs-d-attrs{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:9px}
.gs-d-attr{font-size:8px;padding:2px 8px;border-radius:4px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);color:rgba(255,255,255,.4)}
.gs-d-row{display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.055);border-radius:9px;padding:8px 12px;margin-bottom:8px}
.gs-d-row-l{font-size:9px;color:var(--dim)}
.gs-d-row-v{font-size:14px;font-weight:700}
.gs-d-status{font-size:9px;color:var(--dim);text-align:center;padding:8px;border:1px dashed rgba(255,255,255,.08);border-radius:8px;line-height:1.7}
.gs-d-status.owned{border-color:rgba(16,185,129,.25);color:#6ee7b7;background:rgba(16,185,129,.04)}
.gs-d-status.current{border-color:rgba(201,162,39,.3);color:var(--gl);background:rgba(201,162,39,.05)}


/* вХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХР
   V8 NEW SYSTEMS CSS
вХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХРвХР */

/* Realm Breakthrough Overlay */
#realm-ov{position:fixed;inset:0;z-index:550;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;opacity:0;transition:opacity .3s}
#realm-ov.show{pointer-events:all;opacity:1}
.realm-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 38%,var(--realm-col,rgba(201,162,39,.35)),rgba(0,0,0,.97) 68%)}
.realm-ring{position:absolute;border-radius:50%;border:1px solid var(--realm-col,rgba(201,162,39,.4));animation:realmExpand 1.2s ease forwards}
@keyframes realmExpand{0%{width:0;height:0;opacity:1}100%{width:600px;height:600px;opacity:0;left:50%;top:50%;margin-left:-300px;margin-top:-300px}}
.realm-title{font-family:'Ma Shan Zheng',serif;font-size:36px;letter-spacing:8px;color:var(--realm-col,#ffd700);text-shadow:0 0 30px var(--realm-col,rgba(255,215,0,.8));z-index:1;animation:realmTextIn .6s .3s ease both}
.realm-sub{font-family:'Ma Shan Zheng',serif;font-size:18px;letter-spacing:4px;color:rgba(255,255,255,.7);z-index:1;margin-top:8px;animation:realmTextIn .6s .5s ease both}
.realm-lv{font-size:13px;color:rgba(255,255,255,.4);letter-spacing:2px;z-index:1;margin-top:12px;animation:realmTextIn .6s .7s ease both}
.realm-ico{font-size:64px;z-index:1;margin-bottom:16px;animation:realmIcoIn .5s .1s cubic-bezier(.34,1.56,.64,1) both}
@keyframes realmTextIn{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}
@keyframes realmIcoIn{from{opacity:0;transform:scale(.4)}to{opacity:1;transform:scale(1)}}
.realm-line{width:200px;height:1px;background:linear-gradient(90deg,transparent,var(--realm-col,rgba(255,215,0,.6)),transparent);z-index:1;margin:12px 0;animation:realmTextIn .6s .4s ease both}
.realm-tap{font-size:11px;color:rgba(255,255,255,.28);z-index:1;margin-top:20px;animation:blk 1.5s infinite,realmTextIn .6s .9s ease both}

/* Realm Badge in topbar */
.realm-badge{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:10px;font-size:9px;font-weight:700;letter-spacing:.5px;border:1px solid var(--rb-col,rgba(201,162,39,.4));background:rgba(201,162,39,.08);color:var(--rb-col,var(--gl));transition:all .3s}

/* Talent System */
.talent-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}
.talent-card{border-radius:12px;padding:12px;border:1.5px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03);cursor:pointer;transition:all .22s;position:relative;overflow:hidden}
.talent-card:hover{transform:translateY(-2px)}
.talent-card:active{transform:scale(.95)}
.talent-card.selected{border-color:var(--tc,rgba(245,158,11,.6));background:rgba(var(--tr,245),var(--tg,158),var(--tb,11),.1);box-shadow:0 0 18px rgba(var(--tr,245),var(--tg,158),var(--tb,11),.2)}
.talent-card::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 30%,rgba(var(--tr,245),var(--tg,158),var(--tb,11),.08),transparent 60%);pointer-events:none}
.tc-ico{font-size:28px;margin-bottom:7px}
.tc-name{font-family:'Ma Shan Zheng',serif;font-size:15px;color:var(--tc,var(--gl));letter-spacing:2px;margin-bottom:4px}
.tc-desc{font-size:9px;color:var(--dim);line-height:1.6}
.tc-stats{margin-top:7px;display:flex;flex-direction:column;gap:3px}
.tc-stat{font-size:10px;color:var(--tc,var(--gl));font-weight:600}
.tc-active-badge{position:absolute;top:6px;right:6px;font-size:8px;padding:2px 6px;border-radius:8px;background:var(--tc,rgba(245,158,11,.5));color:#000;font-weight:700}

/* Achievement System */
.ach-card{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:11px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.055);margin-bottom:6px;transition:border-color .2s}
.ach-card.unlocked{border-color:var(--ac,rgba(201,162,39,.35));background:rgba(201,162,39,.04)}
.ach-card.locked{opacity:.42;filter:grayscale(.7)}
.ach-ico-wrap{width:40px;height:40px;border-radius:10px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:20px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07)}
.ach-card.unlocked .ach-ico-wrap{border-color:var(--ac,rgba(201,162,39,.35));background:rgba(201,162,39,.07)}
.ach-body{flex:1;min-width:0}
.ach-name{font-size:11px;font-weight:700;color:var(--txt)}
.ach-desc{font-size:9px;color:var(--dim);margin-top:2px}
.ach-date{font-size:8px;color:var(--dim);margin-top:3px;opacity:.6}
.ach-pts{flex-shrink:0;text-align:right}
.ach-pts-v{font-size:13px;font-weight:700;color:var(--ac,var(--gl))}
.ach-pts-l{font-size:8px;color:var(--dim)}
.ach-tabs{display:flex;gap:5px;padding:0 11px;margin-bottom:10px;flex-wrap:wrap}
.ach-tab{padding:4px 12px;border-radius:20px;border:1px solid var(--bdr);font-size:10px;color:var(--dim);cursor:pointer;transition:all .2s;white-space:nowrap}
.ach-tab.active{border-color:var(--bdrB);color:var(--gl);background:rgba(201,162,39,.1)}

/* Awakening Level (иІЙйЖТз≠ЙзЇІ) */
.awk-level{display:inline-flex;align-items:center;gap:4px;padding:2px 9px;border-radius:10px;font-size:9px;font-weight:700;letter-spacing:.5px;background:rgba(139,92,246,.12);border:1px solid rgba(139,92,246,.3);color:#c4b5fd}
.awk-stars{display:flex;gap:2px;margin-top:4px}
.awk-star{width:10px;height:10px;clip-path:polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);background:rgba(255,255,255,.1)}
.awk-star.lit{background:var(--soul-col,var(--gold));box-shadow:0 0 5px var(--soul-col,var(--gold))}

/* Tidal Lottery */
.tidal-bar{height:6px;border-radius:3px;overflow:hidden;margin:6px 0;background:rgba(255,255,255,.06);position:relative}
.tidal-fill{height:100%;border-radius:3px;transition:width .6s ease}
.tidal-label{font-size:9px;font-weight:700;letter-spacing:.5px}
.tidal-state-0{color:#9ca3af} /* дљОжљЃ */
.tidal-state-1{color:#60a5fa} /* жґ®жљЃ */
.tidal-state-2{color:#f59e0b} /* е§ІжљЃ */
.tidal-state-3{color:#ef4444} /* з•ЮжљЃ */
.tidal-wave{position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.4),transparent);animation:tidalWave 1.4s ease infinite}
@keyframes tidalWave{0%{transform:translateX(-100%)}100%{transform:translateX(200%)}}

/* PVP Arena */
.arena-card{border-radius:14px;padding:14px;margin-bottom:9px;background:linear-gradient(135deg,rgba(239,68,68,.08),rgba(245,158,11,.04));border:1px solid rgba(239,68,68,.25);position:relative;overflow:hidden;cursor:pointer;transition:all .2s}
.arena-card:active{transform:scale(.98)}
.arena-vs{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);font-family:'Ma Shan Zheng',serif;font-size:28px;color:rgba(239,68,68,.6);letter-spacing:2px;pointer-events:none}
.arena-side{display:flex;flex-direction:column;align-items:center;gap:4px}
.arena-ico{font-size:32px}
.arena-name{font-size:10px;font-weight:700;color:var(--txt)}
.arena-pw{font-size:9px;color:var(--gold)}
.honor-bar{display:flex;align-items:center;gap:8px;padding:10px 12px;background:rgba(255,215,0,.06);border:1px solid rgba(255,215,0,.2);border-radius:10px;margin-bottom:10px}

/* Soul Awakening Level display */
.sol-awk-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;background:rgba(139,92,246,.1);border:1px solid rgba(139,92,246,.28);font-size:9px;font-weight:700;color:#c4b5fd;cursor:pointer;transition:border-color .2s}
.sol-awk-badge:hover{border-color:rgba(139,92,246,.55)}

/* Calendar Task Widget */
.cal-header{display:flex;align-items:center;justify-content:space-between;padding:10px 14px 0}
.cal-streak{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--gl);font-weight:700}
.cal-streak-fire{font-size:14px;filter:drop-shadow(0 0 4px rgba(251,146,60,.8))}
.cal-days{display:flex;gap:4px;padding:8px 14px;overflow-x:auto}
.cal-days::-webkit-scrollbar{display:none}
.cal-day{flex-shrink:0;width:36px;border-radius:8px;padding:5px 3px;text-align:center;border:1px solid rgba(255,255,255,.07);background:rgba(255,255,255,.025)}
.cal-day.today{border-color:var(--bdrB);background:rgba(201,162,39,.1)}
.cal-day.done{border-color:rgba(16,185,129,.35);background:rgba(16,185,129,.08)}
.cal-day.bonus{border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.08)}
.cal-day-n{font-size:9px;color:var(--dim);margin-bottom:3px}
.cal-day-ico{font-size:14px;line-height:1}
.cal-day-lbl{font-size:7px;color:var(--dim);margin-top:2px}

/* Combat V8 upgrades */
.combat-flash{position:fixed;inset:0;z-index:600;pointer-events:none;opacity:0;transition:opacity .1s}
.combat-flash.show{opacity:1;animation:combatFlash .4s ease forwards}
@keyframes combatFlash{0%{opacity:.7}100%{opacity:0}}
.hp-seg{flex:1;height:100%;border-right:1px solid rgba(0,0,0,.3);transition:background .3s}
.hp-seg:last-child{border:none}
.phase-badge{display:inline-flex;align-items:center;gap:4px;font-size:8px;padding:2px 7px;border-radius:10px;background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.35);color:#fca5a5;animation:phasePulse 1.5s ease infinite}
@keyframes phasePulse{0%,100%{border-color:rgba(239,68,68,.35)}50%{border-color:rgba(239,68,68,.7);box-shadow:0 0 8px rgba(239,68,68,.3)}}

/* Honor Points in topbar */
.pill.honor{border-color:rgba(255,215,0,.35);background:rgba(255,215,0,.07);color:#fde68a}
</style>
</head>
<body>
<canvas id="C"></canvas>
<div id="SB"></div>
<canvas id="soul-geo-canvas"></canvas>
<div id="app">

<div id="topbar">
  <div class="tb-row">
    <div class="tb-title" onmousedown="gmLongPressStart()" onmouseup="gmLongPressEnd()" onmouseleave="gmLongPressEnd()" ontouchstart="gmLongPressStart()" ontouchend="gmLongPressEnd()" title="йХњжМЙ3зІТињЫеЕ•GM">жЦЧзљЧиІЙйЖТ</div>
    <div class="tb-pills">
      <div class="pill pow">вЪФпЄП <span id="hud-pow">0</span></div>
      <div class="pill">вЪ° <span id="hud-lv">Lv.1</span></div>
      <div class="pill">рЯТЂ <span id="hud-sp">1000</span></div>
      <div class="pill honor" onclick="openAchievements()" style="cursor:pointer">рЯПЖ <span id="hud-honor">0</span></div>
    </div>
  </div>
  <div class="exp-row">
    <div class="exp-wrap"><div class="exp-fill" id="exp-fill" style="width:0%"></div></div>
    <div class="exp-lbl" id="exp-lbl">0 / 100 EXP</div><div id="realm-badge-row" style="display:flex;align-items:center;gap:6px;margin-top:5px"><div class="realm-badge" id="realm-badge" style="--rb-col:rgba(156,163,175,.6)">й≠Ве£Ђ¬ЈеИЭеҐГ</div><div id="awk-badge" style="display:none" class="sol-awk-badge">вЬ¶ иІЙйЖТ Lv.0</div></div>
  </div>
</div>

<div id="notif"></div>

<div id="content">

  <!-- ===== SOUL PAGE ===== -->
  <div class="page active" id="page-soul"></div>

  <!-- ===== HUNT/TRIAL PAGE ===== -->
  <div class="page" id="page-hunt">
    <div class="sh"><div class="st">иѓХзВЉ ¬Ј зЛ©зМО</div><span style="font-size:10px;color:var(--dim)">жђ°жХ∞: <span id="hunt-cnt" style="color:var(--gl);font-weight:700">0</span></span></div>

    <!-- Compact hunt zones grid -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px">
      <div class="zone-card forest" style="padding:10px;margin-bottom:0" onclick="hunt('forest')">
        <div class="z-ico" style="font-size:22px;margin-bottom:4px">рЯМ≤</div>
        <div class="z-nm" style="color:#6ee7b7;font-size:14px;margin-bottom:3px">жШЯжЦЧе§Іж£ЃжЮЧ</div>
        <div style="display:flex;flex-wrap:wrap;gap:3px;margin-bottom:7px">
          <span class="ztag">рЯФЃ зЩЊ~дЄЗеєі</span><span class="ztag">рЯМњ иНѓиНЙ</span><span class="ztag">рЯСС 1%зІ∞еПЈ</span>
        </div>
        <div class="z-cost" style="font-size:10px;padding:3px 8px">100 й≠ВеКЫ</div>
      </div>
      <div class="zone-card chaos" style="padding:10px;margin-bottom:0" onclick="hunt('chaos')">
        <div class="z-ico" style="font-size:22px;margin-bottom:4px">рЯМА</div>
        <div class="z-nm" style="color:#c084fc;font-size:14px;margin-bottom:3px">жЈЈж≤МдєЛеЬ∞</div>
        <div style="display:flex;flex-wrap:wrap;gap:3px;margin-bottom:7px">
          <span class="ztag">рЯТЬ дЄЗ~дЄНдЉ∞йЗП</span><span class="ztag">рЯ¶і й≠Вй™®</span><span class="ztag">рЯСС 1%зІ∞еПЈ</span>
        </div>
        <div class="z-cost" style="font-size:10px;padding:3px 8px">500 й≠ВеКЫ</div>
      </div>
      <div class="zone-card primordial" style="padding:10px;margin-bottom:0" onclick="hunt('primordial')">
        <div class="z-ico" style="font-size:22px;margin-bottom:4px">рЯММ</div>
