let _achFilter='all';
function openAchievements(){
  const sidebar=$('ach-sidebar'),panel=$('ach-panel'),backdrop=$('ach-backdrop');
  if(!sidebar||!panel)return;
  sidebar.style.pointerEvents='all';
  backdrop.style.background='rgba(0,0,0,.75)';
  panel.style.transform='translateX(0)';
  // Check all achievements
  checkAchievements();
  renderAchievements();
}
function closeAchievements(){
  const sidebar=$('ach-sidebar'),panel=$('ach-panel'),backdrop=$('ach-backdrop');
  if(!sidebar||!panel)return;
  sidebar.style.pointerEvents='none';
  backdrop.style.background='rgba(0,0,0,0)';
  panel.style.transform='translateX(100%)';
}
function achFilter(f,el){
  _achFilter=f;
  document.querySelectorAll('.ach-tab').forEach(t=>t.classList.remove('active'));
  if(el)el.classList.add('active');
  renderAchievements();
}
function renderAchievements(){
  const list=$('ach-list');if(!list)return;
  let items=ACH_DEF;
  if(_achFilter!=='all')items=items.filter(a=>a.cat===_achFilter);
  const unlocked=ACH_DEF.filter(a=>G.achievements?.[a.id]);
  const total=ACH_DEF.reduce((s,a)=>s+(G.achievements?.[a.id]?a.pts:0),0);
  $set('ach-unlocked-cnt','textContent',unlocked.length);
  $set('ach-total-cnt','textContent',ACH_DEF.length);
  $set('ach-honor-total','textContent',total);
  $set('hud-honor','textContent',total);
  list.innerHTML=items.map(a=>{
    const done=!!(G.achievements?.[a.id]);
    const ts=done?new Date(G.achievements[a.id].ts).toLocaleDateString('zh-CN'):'';
    return`<div class="ach-card ${done?'unlocked':'locked'}" style="--ac:${a.col}">
      <div class="ach-ico-wrap">${a.ico}</div>
      <div class="ach-body">
        <div class="ach-name">${done?a.n:'???'}</div>
        <div class="ach-desc">${done?a.desc:'еЃМжИРзЙєеЃЪжЭ°дїґиІ£йФБ'}</div>
        ${done?`<div class="ach-date">иІ£йФБ: ${ts}</div>`:''}
      </div>
      <div class="ach-pts">
        <div class="ach-pts-v" style="color:${done?a.col:'var(--dim)'}">${a.pts}</div>
        <div class="ach-pts-l">иН£иАА</div>
      </div>
    </div>`;
  }).join('');
}
function checkAchievement(idHint){
  ACH_DEF.forEach(a=>{
    if(!G.achievements?.[a.id]&&a.check()){
      if(!G.achievements)G.achievements={};
      G.achievements[a.id]={ts:Date.now()};
      G.honorPoints=(G.honorPoints||0)+a.pts;
      notify(`рЯПЖ жИРе∞±иІ£йФБпЉЪ${a.n}пЉБ+${a.pts}иН£иАА`,'legend');
      spawnBurst(a.col||'#ffd700',60);
      $set('hud-honor','textContent',G.honorPoints||0);
      saveG();
    }
  });
}
function checkAchievements(){checkAchievement();}


// вФАвФАвФАвФА TIDAL LOTTERY SYSTEM вФАвФАвФАвФА
// Tidal thresholds per pool
const TIDAL_CFG=[
  {states:[{n:'дљОжљЃ',col:'#9ca3af',cls:'tidal-state-0',next:30},{n:'жґ®жљЃ',col:'#60a5fa',cls:'tidal-state-1',rareBonus:0.2,next:60},{n:'е§ІжљЃ',col:'#f59e0b',cls:'tidal-state-2',legendBonus:0.5,next:90},{n:'з•ЮжљЃ',col:'#ef4444',cls:'tidal-state-3',guarantee:true}]},
  {states:[{n:'дљОжљЃ',col:'#9ca3af',cls:'tidal-state-0',next:25},{n:'жґ®жљЃ',col:'#a78bfa',cls:'tidal-state-1',rareBonus:0.25,next:50},{n:'е§ІжљЃ',col:'#f59e0b',cls:'tidal-state-2',legendBonus:0.6,next:75},{n:'з•ЮжљЃ',col:'#ef4444',cls:'tidal-state-3',guarantee:true}]},
  {states:[{n:'дљОжљЃ',col:'#9ca3af',cls:'tidal-state-0',next:20},{n:'жґ®жљЃ',col:'#f59e0b',cls:'tidal-state-1',rareBonus:0.3,next:40},{n:'е§ІжљЃ',col:'#ef4444',cls:'tidal-state-2',legendBonus:0.7,next:60},{n:'з•ЮжљЃ',col:'#00ffff',cls:'tidal-state-3',guarantee:true}]},
];

function getTidalState(poolIdx){
  const pulls=(G.tidalPulls||[0,0,0])[poolIdx]||0;
  const cfg=TIDAL_CFG[poolIdx];
  let state=cfg.states[0];
  for(const s of cfg.states){
    if(!s.next||pulls<s.next)break;
    state=s;
  }
  return{state,pulls,cfg};
}
function updateTidalUI(poolIdx){
  const {state,pulls,cfg}=getTidalState(poolIdx);
  const fillEl=$('tidal-fill'),lblEl=$('tidal-state-lbl'),nextEl=$('tidal-next-lbl'),cntEl=$('tidal-pull-cnt');
  if(!fillEl)return;
  const stateIdx=cfg.states.indexOf(state);
  const nextState=cfg.states[stateIdx+1];
  const maxPulls=cfg.states[cfg.states.length-1-1]?.next||90;
  const pct=Math.min(100,(pulls/maxPulls)*100);
  // color gradients by tidal state
  const grads=['linear-gradient(90deg,#4b5563,#9ca3af)','linear-gradient(90deg,#3b82f6,#60a5fa)','linear-gradient(90deg,#d97706,#fbbf24)','linear-gradient(90deg,#dc2626,#ef4444)'];
  fillEl.style.background=grads[stateIdx]||grads[0];
  fillEl.style.width=pct+'%';
  if(lblEl){lblEl.textContent=state.n;lblEl.className='tidal-label '+state.cls;}
  if(nextEl)nextEl.textContent=nextState?(state.n+'вЖТ'+nextState.n+' '+nextState.next+'жђ°'):'еЈ≤иЊЊз•ЮжљЃпЉБ';
  if(cntEl)cntEl.textContent=pulls+'жђ°';
}
function advanceTidal(poolIdx,times){
  if(!G.tidalPulls)G.tidalPulls=[0,0,0];
  G.tidalPulls[poolIdx]=(G.tidalPulls[poolIdx]||0)+times;
  const {state}=getTidalState(poolIdx);
  // Reset after guarantee
  if(state.guarantee){
    G.tidalPulls[poolIdx]=0;
    notify(`рЯМК з•ЮжљЃиІ¶еПСпЉБдЄЛжђ°ењЕеЗЇзїЭдЄЦе•ЦеК±пЉБ`,'cosmic');
    spawnBurst('#00ffff',80);
  }
  updateTidalUI(poolIdx);
}
function getTidalBonus(poolIdx){
  const {state}=getTidalState(poolIdx);
  return{rareBonus:state.rareBonus||0, legendBonus:state.legendBonus||0, guarantee:state.guarantee||false};
}

// Patch doLotInternal to update tidal
const _origDoLotInternal=doLotInternal;
function doLotInternal(cfg,modeIdx,times,fromTicket){
  advanceTidal(modeIdx,times);
  updateTidalUI(modeIdx);
  _origDoLotInternal(cfg,modeIdx,times,fromTicket);
}

// вФАвФАвФАвФА CALENDAR SYSTEM вФАвФАвФАвФА
const CAL_REWARDS=[
  {day:1,ico:'рЯОЯпЄП',lbl:'жЩЃйАЪеИЄ√Ч3', fn:()=>addTicketToBag('common',3)},
  {day:2,ico:'рЯТЂ',lbl:'й≠ВеКЫ+2000', fn:()=>addSP(2000,'еОЖж≥Хе•ЦеК±')},
  {day:3,ico:'рЯОЂ',lbl:'йЂШзЇІеИЄ√Ч2', fn:()=>addTicketToBag('advanced',2)},
  {day:4,ico:'рЯ¶і',lbl:'йЪПжЬЇй≠Вй™®',  fn:()=>{const bp=BONE_POOL[pick(['head','body','arm','leg'])];const b=bp[ri(0,3)];const pw=genBonePw(b.tier);bagPush('bone',{...b,pw,id:Date.now()});}},
  {day:5,ico:'рЯОЂ',lbl:'йЂШзЇІеИЄ√Ч5', fn:()=>addTicketToBag('advanced',5)},
  {day:6,ico:'рЯТЂ',lbl:'й≠ВеКЫ+10000',fn:()=>addSP(10000,'еОЖж≥Хе•ЦеК±')},
  {day:7,ico:'рЯПЖ',lbl:'й°ґзЇІеНБињЮеИЄ',fn:()=>addTicketToBag('apex',1,true)},
];
function checkCalendarLogin(){
  const now=Date.now();
  const lastDay=G.calendarLastLogin||0;
  const dayMs=86400000;
  const daysSinceLast=Math.floor((now-lastDay)/dayMs);
  if(daysSinceLast===0)return; // already logged in today
  if(daysSinceLast===1){
    G.calendarStreak=(G.calendarStreak||0)+1;
  } else {
    G.calendarStreak=1; // streak broken
    G.calendarDay7Claimed=false;
  }
  G.calendarLastLogin=now;
  // Auto-claim day reward (days 1-6)
  const dayInCycle=(G.calendarStreak-1)%7+1;
  const rew=CAL_REWARDS[dayInCycle-1];
  if(rew){
    rew.fn();
    notify(`рЯУЕ еОЖж≥Хе•ЦеК±¬Јзђђ${dayInCycle}е§©пЉЪ${rew.lbl}`,'divine');
    if(dayInCycle===7&&!G.calendarDay7Claimed){G.calendarDay7Claimed=true;}
    if(G.calendarStreak>=7)checkAchievement('calendar7');
  }
  saveG();renderCalendar();
}
function renderCalendar(){
  const row=$('cal-days-row');if(!row)return;
  const streak=G.calendarStreak||0;
  const dayInCycle=(streak===0?0:(streak-1)%7+1);
  $set('cal-streak-n','textContent',streak);
  // Show 7-day cycle
  row.innerHTML=CAL_REWARDS.map((r,i)=>{
    const dayN=i+1;
    const done=dayN<dayInCycle;
    const today=dayN===dayInCycle;
    const isBonus=dayN===7;
    let cls='cal-day'+(isBonus?' bonus':today?' today':done?' done':'');
    return`<div class="${cls}">
      <div class="cal-day-n">зђђ${dayN}е§©</div>
      <div class="cal-day-ico">${done?'вЬЕ':r.ico}</div>
      <div class="cal-day-lbl">${r.lbl.slice(0,4)}</div>
    </div>`;
  }).join('');
  // Claim button for day 7
  const claimBtn=$('cal-claim-btn');
  if(claimBtn){claimBtn.style.display='none';}
}
function claimCalendar(){
  notify('дїКжЧ•е•ЦеК±еЈ≤иЗ™еК®еПСжФЊпЉБ','normal');
}


// вФАвФАвФАвФА PVP ARENA SYSTEM вФАвФАвФАвФА
const ARENA_ENEMIES=[
  {n:'еИГй≠Ве∞Сеєі',    ico:'вЪФпЄП', pw:5000,   atk:300,  hp:8000,  spd:12, q:'common',  desc:'еИЭеЗЇиМЕеЇРзЪДеЙСз≥їй≠ВеЄИ'},
  {n:'еЖ∞йЬЬдљњиАЕ',    ico:'вЭДпЄП', pw:15000,  atk:600,  hp:15000, spd:10, q:'rare',    desc:'еЖ∞з≥їй≠ВеЄИпЉМйШ≤еЊ°дЄЇдЄї'},
  {n:'йЫЈйЬЖжИШе£Ђ',    ico:'вЪ°', pw:30000,  atk:1200, hp:25000, spd:16, q:'epic',    desc:'йЫЈз≥їй≠ВеЄИпЉМжФїеЗїеЗґзМЫ'},
  {n:'жЪЧељ±еИЇеЃҐ',    ico:'рЯМС', pw:60000,  atk:2500, hp:20000, spd:22, q:'epic',    desc:'жЪЧз≥їй≠ВеЄИпЉМењЂеЗЖзЛ†'},
  {n:'дЉ†иѓій≠ВеЄЭ',    ico:'рЯФ•', pw:120000, atk:5000, hp:80000, spd:14, q:'legend',  desc:'й°ґе∞Цй≠ВеЄЭпЉМеЕ®йЭҐеЉЇиАЕ'},
  {n:'з•ЮиµРеАЩйАЙ',    ico:'вЬ®', pw:300000, atk:12000,hp:200000,spd:18, q:'apex',    desc:'з•ЮзЇІжИШеКЫеАЩйАЙиАЕ'},
  {n:'жЈЈж≤МдєЛдЄї',    ico:'рЯМА', pw:600000, atk:25000,hp:500000,spd:20, q:'ha',      desc:'жЈЈж≤Ме±ЮжАІпЉМйЪЊдї•жНЙжСЄ'},
  {n:'еЃЗеЃЩеЃИжЬЫиАЕ',  ico:'рЯММ', pw:1500000,atk:60000,hp:1000000,spd:25,q:'triple', desc:'иІ¶зҐ∞еЃЗеЃЩж≥ХеИЩзЪДеЉЇиАЕ'},
];
const ARENA_HONOR_REWARDS=[
  {honor:100, n:'зЂЮжКАеЬЇжЦ∞дЇЇ', ticket:'common',  count:5,  ten:false},
  {honor:300, n:'еИЭзЇІзЂЮжКАиАЕ',ticket:'advanced', count:3,  ten:false},
  {honor:600, n:'иН£иААжИШе£Ђ',  ticket:'advanced', count:10, ten:false},
  {honor:1000,n:'зЂЮжКАз≤ЊиЛ±',  ticket:'apex',     count:3,  ten:false},
  {honor:2000,n:'зЂЮжКАе§ІеЄИ',  ticket:'apex',     count:1,  ten:true},
  {honor:5000,n:'зЂЮжКАзОЛиАЕ',  ticket:'apex',     count:5,  ten:true},
];

function renderArenaPage(){
  const pw=calcPower();
  const honor=G.arenaHonor||0;
  // Find matchable opponents (pw within 0.3x ~ 3x range)
  const opponents=ARENA_ENEMIES.filter(e=>{
    const ratio=pw/e.pw;
    return ratio>=0.2&&ratio<=5;
  });
  if(!opponents.length){
    // fallback: closest enemy
    opponents.push(ARENA_ENEMIES.reduce((prev,cur)=>
      Math.abs(cur.pw-pw)<Math.abs(prev.pw-pw)?cur:prev));
  }
  // Pick 3 random matches
  const shuffled=[...opponents].sort(()=>Math.random()-.5).slice(0,3);
  // Honor milestone display
  const nextMilestone=ARENA_HONOR_REWARDS.find(r=>r.honor>honor);
  const prevMilestone=ARENA_HONOR_REWARDS.slice().reverse().find(r=>r.honor<=honor);
  const claimables=ARENA_HONOR_REWARDS.filter(r=>r.honor<=honor&&!G.achievements?.['arena_honor_'+r.honor]);

  const matchesH=shuffled.map(e=>{
    const qc=QC[e.q]||QC.common;
    const winRate=Math.min(95,Math.max(5,Math.round(pw/(pw+e.pw)*100)));
    return`<div class="arena-card" onclick="startArenaMatch('${e.n}')">
      <div style="display:flex;align-items:center;justify-content:space-between">
        <div class="arena-side">
          <div class="arena-ico">${G.soul?.icon||'вЪ°'}</div>
          <div class="arena-name">${G.soul?.name||'й≠ВеЄИ'}</div>
          <div class="arena-pw">жИШеКЫ ${pw.toLocaleString()}</div>
        </div>
        <div class="arena-vs">VS</div>
        <div class="arena-side">
          <div class="arena-ico">${e.ico}</div>
          <div class="arena-name" style="color:${qc.c}">${e.n}</div>
          <div class="arena-pw">жИШеКЫ ${e.pw.toLocaleString()}</div>
        </div>
      </div>
      <div style="margin-top:8px;display:flex;align-items:center;justify-content:space-between">
        <div style="font-size:9px;color:var(--dim)">${e.desc}</div>
        <div style="font-size:10px;font-weight:700;color:${winRate>=60?'var(--hc)':winRate>=40?'var(--gold)':'var(--apex)'}">иГЬзОЗвЙИ${winRate}%</div>
      </div>
      <div style="display:flex;gap:4px;justify-content:flex-end;margin-top:6px">
        <span style="font-size:9px;padding:2px 8px;border-radius:4px;background:rgba(201,162,39,.1);border:1px solid var(--bdrB);color:var(--gl)">рЯПЖ +${Math.ceil(e.pw/1000)} иН£иАА</span>
        <span style="font-size:9px;padding:2px 8px;border-radius:4px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);color:var(--dim)">жґИиАЧ 1 дї§зЙМ</span>
      </div>
    </div>`;
  }).join('');

  const milestoneH=ARENA_HONOR_REWARDS.map(r=>{
    const claimed=!!(G.achievements?.['arena_honor_'+r.honor]);
    const reachable=honor>=r.honor;
    return`<div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.04);opacity:${claimed?.4:1}">
      <div style="width:32px;height:32px;border-radius:8px;background:${reachable?'rgba(201,162,39,.1)':'rgba(255,255,255,.03)'};border:1px solid ${reachable?'var(--bdrB)':'var(--bdr)'};display:flex;align-items:center;justify-content:center;font-size:14px">${claimed?'вЬЕ':reachable?'рЯОБ':'рЯФТ'}</div>
      <div style="flex:1">
        <div style="font-size:11px;font-weight:700;color:${reachable?'var(--txt)':'var(--dim)'}">${r.n}</div>
        <div style="font-size:9px;color:var(--dim)">иН£иАА ${r.honor} ¬Ј ${r.n==='зЂЮжКАеЬЇжЦ∞дЇЇ'?'жЩЃйАЪ':''}еИЄ√Ч${r.count}${r.ten?'(еНБињЮ)':''}</div>
      </div>
      ${reachable&&!claimed?`<div onclick="claimArenaReward('${r.honor}')" class="m-btn ok" style="padding:4px 10px;font-size:10px;cursor:pointer">йҐЖеПЦ</div>`:''}
    </div>`;
  }).join('');

  return`<div style="display:flex;flex-direction:column;gap:0">
    <div class="honor-bar">
      <div style="font-size:20px">рЯПЖ</div>
      <div style="flex:1">
        <div style="display:flex;justify-content:space-between;margin-bottom:3px">
          <span style="font-size:11px;font-weight:700;color:#fde68a">зЂЮжКАиН£иАА</span>
          <span style="font-size:11px;color:var(--gl);font-weight:700">${honor}</span>
        </div>
        ${nextMilestone?`<div style="height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden">
          <div style="height:100%;width:${Math.min(100,(honor/nextMilestone.honor)*100)}%;background:linear-gradient(90deg,#b45309,#fde68a);border-radius:2px;transition:width .5s"></div>
        </div>
        <div style="font-size:8px;color:var(--dim);margin-top:2px">дЄЛдЄАйЗМз®ЛзҐС ${nextMilestone.honor}пЉИ${nextMilestone.n}пЉЙ</div>`:'<div style="font-size:9px;color:#fde68a">еЈ≤иЊЊжЬАйЂШйЗМз®ЛзҐСпЉБ</div>'}
      </div>
      <div style="text-align:right">
        <div style="font-size:10px;color:var(--dim)">${G.arenaWins||0}иГЬ ${G.arenaLosses||0}иі•</div>
      </div>
    </div>
    <div class="sh" style="margin-bottom:8px"><div class="st">вЪФпЄП еМєйЕНеѓєжЙЛ</div><span style="font-size:9px;color:var(--dim)">жѓПеЬЇжґИиАЧ1еЉВзХМдї§зЙМ</span></div>
    ${matchesH}
    <div class="sh" style="margin:10px 0 8px 0"><div class="st">рЯОБ иН£иААйЗМз®ЛзҐС</div></div>
    ${milestoneH}
  </div>`;
}

function startArenaMatch(enemyName){
  initAbyssState();tickAbyssTokens();
  if(G.abyss.tokens<1){notify('еЉВзХМдї§зЙМдЄНиґ≥пЉБ','normal');return;}
  if(!G.awakenDone||!G.soul){notify('иѓЈеЕИиІЙйЖТж≠¶й≠ВпЉБ','normal');return;}
  const enemy=ARENA_ENEMIES.find(e=>e.n===enemyName)||ARENA_ENEMIES[0];
  G.abyss.tokens--;
  saveG();
  // Build arena combat state
  const player=buildPlayerStats();
  player.hp=player.maxHp;
  const pw=calcPower();
  const winRate=Math.min(0.95,Math.max(0.05,pw/(pw+enemy.pw)));
  // Apply talent combat bonus
  const tb=getTalentBonus();
  if(tb.atkMul)player.atk=Math.floor(player.atk*tb.atkMul);
  if(tb.hpMul)player.maxHp=Math.floor(player.maxHp*tb.hpMul);
  if(tb.defMul)player.def=Math.floor((player.def||0)*tb.defMul);
  player.hp=player.maxHp;
  const enemyObj={
    n:enemy.n,i:enemy.ico,maxHp:enemy.hp,hp:enemy.hp,
    atk:enemy.atk,spd:enemy.spd,statuses:{},
    skills:[{n:'зЂЮжКАињЮеЗї',d:'ињЮзї≠жФїеЗї',dmg:Math.floor(enemy.atk*1.8),cd:3,curCd:0,icon:'вЪФпЄП'}]
  };
  const fakeLayer={n:'зЂЮжКАеЬЇ',col:'#ef4444'};
  const fakeStage={n:enemy.n,type:'elite',cost:0,enemy:enemyObj};
  combatState={player,enemy:enemyObj,round:1,maxRounds:8,stage:fakeStage,layer:fakeLayer,
    turnOrder:[],log:[],phase:0,ended:false,speed:'normal',isArena:true,arenaEnemy:enemy};
  combatLog=[];
  $set('ab-tokens','textContent',G.abyss.tokens);
  showCombatUI();
}

// Arena result handling injected into combat flow via flag check in closeCombat
function handleArenaResult(won){
  if(won){
    const e=combatState?.arenaEnemy;
    const honor=Math.ceil((e?.pw||1000)/1000);
    G.arenaHonor=(G.arenaHonor||0)+honor;
    G.arenaWins=(G.arenaWins||0)+1;
    if((G.arenaWins||0)>=10)checkAchievement('arena10');
    ARENA_HONOR_REWARDS.forEach(r=>{
      const key='arena_honor_'+r.honor;
      if(G.arenaHonor>=r.honor&&!G.achievements?.[key]){
        notify(`рЯОБ зЂЮжКАеЬЇйЗМз®ЛзҐСпЉЪ${r.n}пЉБиН£иАА${r.honor}пЉБеЙНеЊАзЂЮжКАеЬЇйҐЖеПЦе•ЦеК±пЉБ`,'legend');
      }
    });
    addLog('\n> рЯПЖ зЂЮжКАеЬЇиГЬеИ©пЉБиОЈеЊЧ '+honor+' иН£иААпЉБељУеЙНпЉЪ'+G.arenaHonor,'#22c55e');
  } else {
    G.arenaLosses=(G.arenaLosses||0)+1;
    G.arenaHonor=(G.arenaHonor||0)+5;
    addExp(300);
    addLog('\n> рЯТФ зЂЮжКАеЬЇиРљиі•... иН£иАА+5 зїПй™М+300','#f87171');
  }
  saveG();
}

function claimArenaReward(honor){
  const r=ARENA_HONOR_REWARDS.find(x=>x.honor==honor);if(!r)return;
  if(!G.achievements)G.achievements={};
  if(G.achievements['arena_honor_'+honor]){notify('еЈ≤йҐЖеПЦ','normal');return;}
  G.achievements['arena_honor_'+honor]={ts:Date.now()};
  addTicketToBag(r.ticket,r.count,r.ten||false);
  notify(`рЯОБ ${r.n} е•ЦеК±йҐЖеПЦпЉБ${r.ticket==='apex'?'й°ґзЇІ':'йЂШзЇІ'}еИЄ√Ч${r.count}`,'divine');
  spawnBurst('#ffd700',60);
  saveG();renderAbyssPage();
}


// вФАвФАвФАвФА V8 BUG FIXES вФАвФАвФАвФА
// Fix: GM long press fires on touchmove (mobile scroll)
(function(){
  const titleEl=document.querySelector('.tb-title');
  if(!titleEl)return;
  let _startY=0;
  titleEl.addEventListener('touchmove',function(e){
    const dy=Math.abs(e.touches[0].clientY-_startY);
    if(dy>10){clearTimeout(gmPressTimer);gmPressTimer=null;}
  },{passive:true});
  titleEl.addEventListener('touchstart',function(e){_startY=e.touches[0].clientY;},{passive:true});
})();

// Fix: bagFab shows correct icon
function toggleBagFab(){
  _bagOpen=!_bagOpen;
  const fab=$('bag-fab');
  if(_bagOpen){
    let bagOv=$('bag-overlay');
    if(!bagOv){
      bagOv=document.createElement('div');
      bagOv.id='bag-overlay';
      bagOv.style.cssText='position:fixed;inset:0 0 58px 0;z-index:90;background:linear-gradient(180deg,#050810,#08101a);overflow-y:auto;animation:sUp .25s ease;padding:11px';
      bagOv.innerHTML='<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px"><div class="st">рЯОТ иГМеМЕ</div></div>'+
        '<div class="bag-tabs" id="bag-tabs-ov"><div class="btab active" onclick="fBagOv(\'all\',this)">еЕ®йГ®</div><div class="btab" onclick="fBagOv(\'bone\',this)">й≠Вй™®</div><div class="btab" onclick="fBagOv(\'artifact\',this)">з•ЮеЩ®</div><div class="btab" onclick="fBagOv(\'herb\',this)">иНѓиНЙ</div><div class="btab" onclick="fBagOv(\'resource\',this)">иµДжЇР</div><div class="btab" onclick="fBagOv(\'ticket\',this)">е•ЦеИЄ</div></div>'+
        '<div class="bag-grid" id="bag-grid-ov"></div>';
      $('app').appendChild(bagOv);
    }
    bagOv.style.display='block';
    curBagFilter='all';
    renderBagOv();
    if(fab){fab.classList.add('open');fab.innerHTML='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:20px;height:20px;display:block"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';}
  } else {
    const bagOv=$('bag-overlay');if(bagOv)bagOv.style.display='none';
    if(fab){fab.classList.remove('open');fab.innerHTML='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:22px;height:22px;display:block"><path d="M6 9V7.5A5.5 5.5 0 0117 7.5V9"/><path d="M3.5 9h17L19 20.5H5L3.5 9z"/><path d="M9.5 13.5h5" stroke-width="1.2" opacity=".6"/></svg>';}
  }
}

// вФАвФАвФАвФА COMBAT V8 UPGRADE: Flash effect + Segmented HP вФАвФАвФАвФА
function combatFlash(col){
  const f=$('combat-flash');if(!f)return;
  f.style.background=col||'rgba(239,68,68,.4)';
  f.classList.add('show');
  setTimeout(()=>f.classList.remove('show'),400);
}

// Flash helpers called from combat actions (non-overriding)
function doAttackV8(){
  if(!combatState||combatState.ended)return;
  combatFlash('rgba(201,162,39,.25)');
  doAttack();
}
function useSkillV8(idx){
  if(!combatState||combatState.ended)return;
  combatFlash('rgba(124,58,237,.3)');
  useSkill(idx);
}

// вФАвФАвФАвФА V8 INIT ADDITIONS вФАвФАвФАвФА
function v8Init(){
  // Migration for v10
  if(!G.realmMilestones)G.realmMilestones=[];
  if(!G.talent&&G.talent!==null)G.talent=null;
  if(!G.achievements)G.achievements={};
  if(!G.honorPoints)G.honorPoints=0;
  if(!G.arenaHonor)G.arenaHonor=0;
  if(!G.arenaWins)G.arenaWins=0;
  if(!G.arenaLosses)G.arenaLosses=0;
  if(!G.calendarStreak)G.calendarStreak=0;
  if(!G.calendarLastLogin)G.calendarLastLogin=0;
  if(!G.calendarDay7Claimed)G.calendarDay7Claimed=false;
  if(G.awakenLevel===undefined)G.awakenLevel=0;
  if(!G.tidalPulls)G.tidalPulls=[0,0,0];
  // Check calendar login
  checkCalendarLogin();
  // Update realm badge
  updateRealmBadge();
  // Check all achievements on startup
  setTimeout(()=>checkAchievements(),500);
  // Update honor in HUD
  $set('hud-honor','textContent',G.honorPoints||0);
  // Init tidal UI
  setTimeout(()=>updateTidalUI(0),200);
}

// V8: tidal update happens via goLotPool patch

// V8: tidal updated inline when goLotPool is called

</script>
</body>
</html>
