    <div style="height:12px"></div>
  </div>

  <!-- ===== ABYSS PAGE ===== -->
  <div class="page" id="page-abyss">
    <div class="sh">
      <div class="st">рЯМН дЄЦзХМжОҐзіҐ</div>
      <span style="font-size:10px;color:var(--dim)">дї§зЙМ: <span id="ab-tokens" style="color:var(--gl);font-weight:700">0</span>/10 &nbsp;<span style="color:var(--dim)">¬Ј</span>&nbsp; рЯФЃ <span id="ab-shards" style="color:var(--gl);font-weight:700">0</span></span>
    </div>
