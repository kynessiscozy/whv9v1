  {lv:21, n:'е§Ій≠ВеЄИ', sub:'дЄЙзОѓеВНиЇЂпЉМеИЭйЬ≤йФЛиКТ', ico:'рЯФЃ', col:'#34d399', glow:'rgba(52,211,153,.6)'},
  {lv:31, n:'й≠Ве∞К',   sub:'еЫЫзОѓдєЛеКЫпЉМзЛђељУдЄАйЭҐ', ico:'рЯТЂ', col:'#a78bfa', glow:'rgba(167,139,250,.6)'},
  {lv:41, n:'й≠ВеЃЧ',   sub:'дЇФзОѓиЬХеПШпЉМиЄПеЕ•еЉЇиАЕдєЛеИЧ',ico:'рЯМА', col:'#f59e0b', glow:'rgba(245,158,11,.6)'},
  {lv:51, n:'й≠ВзОЛ',   sub:'еЕ≠зОѓе®БеОЛпЉМдЄЗдЇЇдєЛдЄК', ico:'рЯСС', col:'#fb923c', glow:'rgba(251,146,60,.6)'},
  {lv:61, n:'й≠ВеЄЭ',   sub:'дЄГзОѓеРЫдЄіпЉМдЄАжЦєеЄЭиАЕ', ico:'рЯФ•', col:'#f87171', glow:'rgba(248,113,113,.6)'},
  {lv:71, n:'й≠ВеЬ£',   sub:'еЕЂзОѓеЬ£еҐГпЉМиґЕеЗ°еЕ•еЬ£', ico:'вЬ®', col:'#e879f9', glow:'rgba(232,121,249,.6)'},
  {lv:81, n:'й≠ВжЦЧзљЧ', sub:'дєЭзОѓељТдљНпЉМжЦЧзљЧеҐГзХМ', ico:'рЯРЙ', col:'#ffd700', glow:'rgba(255,215,0,.7)'},
  {lv:91, n:'е∞БеПЈжЦЧзљЧ',sub:'е∞БеПЈе§©иµЛпЉМеРНеК®еЫЫжЦє', ico:'вЪФпЄП', col:'#ef4444', glow:'rgba(239,68,68,.7)'},
  {lv:95, n:'иґЕзЇІжЦЧзљЧ',sub:'иґЕиґКжЮБйЩРпЉМз•ЮдєЛйЧ®жІЫ', ico:'рЯМЯ', col:'#ff6b6b', glow:'rgba(255,107,107,.7)'},
  {lv:99, n:'жЮБйЩРжЦЧзљЧ',sub:'жЦЧзљЧдєЛеЈЕпЉМдњѓиІЖдЉЧзФЯ', ico:'вИЮ', col:'#00ffff', glow:'rgba(0,255,255,.7)'},
  {lv:100,n:'з•ЮзЇІ',   sub:'иЄПеЕ•з•ЮдєЛйҐЖеЯЯпЉМиґЕиґКеЗ°йЧі', ico:'рЯЩП', col:'#fffbeb', glow:'rgba(255,251,235,.8)'},
];

function getCurrentRealm(lv){
  let r=REALMS[0];
  for(const realm of REALMS){if(lv>=realm.lv)r=realm;else break;}
  return r;
}
function getNextRealm(lv){
  for(const realm of REALMS){if(realm.lv>lv)return realm;}
  return null;
}

function updateRealmBadge(){
  const r=getCurrentRealm(G.level);
  const badge=$('realm-badge');
  if(!badge)return;
  badge.textContent=r.n+'¬ЈеҐГ';
  badge.style.setProperty('--rb-col',r.col);
  // Awaken badge
  const ab=$('awk-badge');
  if(ab){
    if(G.soul&&G.awakenLevel>0){
      ab.style.display='inline-flex';
      ab.textContent='вЬ¶ иІЙйЖТ Lv.'+G.awakenLevel;
    } else {ab.style.display='none';}
  }
}

function checkRealmBreakthrough(lv){
  const r=getCurrentRealm(lv);
  // Only trigger on exact realm boundary levels
  const isBreakthrough=REALMS.some(rm=>rm.lv===lv);
  if(!isBreakthrough){
    notify('рЯОЙ еНЗзЇІпЉБ'+rankStr(lv),'legend');
    spawnBurst('#ffd700',55);
    return;
  }
  // Big realm breakthrough!
  spawnBurst(r.glow.replace('rgba','rgb').replace(/,[^,]+\)$/,')'),120);
  setTimeout(()=>showRealmOverlay(r),300);
}

function showRealmOverlay(r){
  const ov=$('realm-ov');if(!ov)return;
  ov.style.setProperty('--realm-col',r.col);
  $set('realm-ico','textContent',r.ico);
  $set('realm-title','textContent',r.n);
  $set('realm-sub','textContent',r.sub);
  $set('realm-lv','textContent','Lv.'+G.level+' ¬Ј '+rankStr(G.level));
  const bg=$('realm-bg');
  if(bg)bg.style.background=`radial-gradient(ellipse at 50% 38%,${r.glow.replace(/,[^,]+\)$/,',.4)')},rgba(0,0,0,.97) 68%)`;
  // Spawn ring animation
  const ring=document.createElement('div');
  ring.className='realm-ring';
  ring.style.setProperty('--realm-col',r.col+'50');
  ov.appendChild(ring);
  setTimeout(()=>ring.remove(),1300);
  ov.classList.add('show');
  // Auto close after 5s
  setTimeout(()=>closeRealmOverlay(),5000);
  // Grant realm bonus
  grantRealmBonus(r);
  // Unlock talent at Lv.91
  if(G.level===91&&!G.talent){
    setTimeout(()=>{closeRealmOverlay();openTalentSelect();},1200);
  }
}

function closeRealmOverlay(){
  const ov=$('realm-ov');if(ov)ov.classList.remove('show');
}

function grantRealmBonus(r){
  const bonuses={
    11:{sp:500,exp:0,msg:'й≠ВеЄИеҐГе•ЦеК±пЉЪй≠ВеКЫ+500'},
    21:{sp:1000,exp:0,msg:'е§Ій≠ВеЄИеҐГе•ЦеК±пЉЪй≠ВеКЫ+1000'},
    31:{sp:2000,exp:0,ticket:'common',ticketN:3,msg:'й≠Ве∞КеҐГе•ЦеК±пЉЪй≠ВеКЫ+2000¬ЈжЩЃйАЪеИЄ√Ч3'},
    41:{sp:5000,exp:0,ticket:'advanced',ticketN:2,msg:'й≠ВеЃЧеҐГе•ЦеК±пЉЪй≠ВеКЫ+5000¬ЈйЂШзЇІеИЄ√Ч2'},
    51:{sp:10000,exp:0,ticket:'advanced',ticketN:5,msg:'й≠ВзОЛеҐГе•ЦеК±пЉЪй≠ВеКЫ+10000¬ЈйЂШзЇІеИЄ√Ч5'},
    61:{sp:20000,exp:0,ticket:'apex',ticketN:2,msg:'й≠ВеЄЭеҐГе•ЦеК±пЉЪй≠ВеКЫ+20000¬Јй°ґзЇІеИЄ√Ч2'},
    71:{sp:50000,exp:0,ticket:'apex',ticketN:5,msg:'й≠ВеЬ£еҐГе•ЦеК±пЉЪй≠ВеКЫ+50000¬Јй°ґзЇІеИЄ√Ч5'},
    81:{sp:100000,exp:0,ticket:'apex',ticketN:10,msg:'й≠ВжЦЧзљЧеҐГе•ЦеК±пЉЪй°ґзЇІеНБињЮеИЄ√Ч1'},
    91:{sp:200000,ticket:'apex',ticketN:10,ten:true,msg:'е∞БеПЈжЦЧзљЧеҐГе•ЦеК±пЉЪй°ґзЇІеНБињЮеИЄ√Ч1¬ЈиІ£йФБе∞БеПЈе§©иµЛ'},
    95:{sp:500000,ticket:'apex',ticketN:10,ten:true,msg:'иґЕзЇІжЦЧзљЧеҐГе•ЦеК±пЉЪй°ґзЇІеНБињЮеИЄ√Ч1'},
    99:{sp:1000000,ticket:'apex',ticketN:30,ten:true,msg:'жЮБйЩРжЦЧзљЧеҐГе•ЦеК±пЉЪй°ґзЇІеНБињЮеИЄ√Ч3'},
    100:{sp:5000000,ticket:'apex',ticketN:50,ten:true,msg:'з•ЮзЇІеҐГе•ЦеК±пЉЪй°ґзЇІеНБињЮеИЄ√Ч5¬ЈжИШеКЫ+500000'},
  };
  const b=bonuses[r.lv];if(!b)return;
  if(b.sp)G.sp+=b.sp;
  if(b.power)G.extraPower+=b.power;
  if(b.ticket)addTicketToBag(b.ticket,b.ticketN,b.ten||false);
  if(r.lv===100)G.extraPower+=500000;
  setTimeout(()=>notify('рЯОБ '+b.msg,'divine'),800);
  updateHUD();saveG();
}


