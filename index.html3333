  {id:4,n:"з•Юй≠Фз¶БеЬ∞",col:"#ef4444",req:90,stages:[{id:"4-1",n:"з•Юй≠ФйҐЖеЯЯ",type:"normal",cost:2,enemy:{n:"е†ХиРљз•Юдљњ",i:"рЯШИ",hp:135000,atk:13000,spd:18,skills:[{n:"з•Юй≠ФдєЛеКЫ",d:"жѓБзБ≠жАІжФїеЗї",dmg:13000,cd:3,icon:"рЯТА"},{n:"з•ЮеЬ£зЗГзГІ",d:"з•ЮеЬ£зБЂзД∞зБЉзГІ",dmg:1500,cd:2,status:"burn",icon:"рЯФ•"}]}}]},
  {id:5,n:"еЃЗеЃЩжЬђжЇР",col:"#00ffff",req:100,stages:[{id:"5-1",n:"еЃЗеЃЩиµЈзВє",type:"normal",cost:3,enemy:{n:"еЃЗеЃЩжДПењЧеМЦиЇЂ",i:"вИЮ",hp:450000,atk:32500,spd:25,skills:[{n:"еЃЗеЃЩжєЃзБ≠",d:"ињСдєОжѓБзБ≠зЪДжФїеЗї",dmg:41600,cd:4,icon:"рЯТ•"},{n:"иІДеИЩйЗНеЖЩ",d:"жЧ†иІЖдЄАеИЗйШ≤еЊ°",dmg:5000,cd:3,icon:"вЪ°"}]}}]},
];

