  {id:"t2",n:"еЉВзХМдї§зЙМ√Ч3пЉИй≠ВеКЫпЉЙ",i:"рЯФС",costType:"sp",cost:2500,fn:()=>{G.abyss.tokens=Math.min(G.abyss.maxTokens,G.abyss.tokens+3);}},
  {id:"t3",n:"еЉВзХМдї§зЙМ√Ч10пЉИжї°еЕЕпЉЙ",i:"рЯФС",costType:"shards",cost:300,fn:()=>{G.abyss.tokens=G.abyss.maxTokens;$set('ab-tokens','textContent',G.abyss.tokens);}},
  // Tickets
