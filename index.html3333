    <div class="sh"><div class="st">й≠ВзОѓиЮНеРИ</div></div>
    <div class="card">
      <div style="font-size:11px;color:var(--dim);margin-bottom:9px;line-height:1.7">йАЙжЛ©дЄ§дЄ™й≠ВзОѓиЮНеРИпЉМжЈїеК†иНѓиНЙеПѓжПРеНЗжИРеКЯзОЗдЄОиі®еПШж¶ВзОЗгАВдЄНеПѓдЉ∞йЗПеПКдї•дЄКй≠ВзОѓиЮНеРИеПѓиГљиІ¶еПСз•Юе•ЗжХИжЮЬгАВ</div>
      <div class="fus-circles">
        <div class="f-c" id="fc-a" onclick="selFR('a')">
          <div id="fc-ai" style="font-size:20px">в≠Х</div>
          <div id="fc-an" style="font-size:8px;margin-top:2px;text-align:center">йАЙжЛ©A</div>
        </div>
        <div class="f-plus">+</div>
        <div class="f-c" id="fc-b" onclick="selFR('b')">
          <div id="fc-bi" style="font-size:20px">в≠Х</div>
          <div id="fc-bn" style="font-size:8px;margin-top:2px;text-align:center">йАЙжЛ©B</div>
        </div>
        <div style="font-size:16px;color:var(--dim)">=</div>
        <div class="f-c result" id="fc-res">
