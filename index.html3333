  {id:"s2",n:"йЂШзЇІжШЯињРеИЄ√Ч2",i:"рЯОЂ",costType:"shards",cost:80,fn:()=>{addTicketToBag('advanced',2);}},
  {id:"s3",n:"й°ґзЇІжШЯињРеНБињЮеИЄ√Ч1",i:"рЯПЖ",costType:"shards",cost:300,fn:()=>{addTicketToBag('apex',1,true);}},
  // Bones & gear
