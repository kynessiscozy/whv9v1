    const itEl=$('idle-txt');if(itEl)itEl.textContent=G.idleEarned+'/5000';
    const ibEl=$('idle-bar');if(ibEl)ibEl.style.width=Math.min(100,G.idleEarned/50)+'%';
    if(Math.random()<0.001)saveG();
  }
},1000);
