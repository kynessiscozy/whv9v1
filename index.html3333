      <div class="gm-btn gm-btn-r" onclick="gmDivineSoul()">з•ЮзЇІж≠¶й≠В</div>
      <div class="gm-btn gm-btn-r" onclick="gmChuSoul()">ж≠¶й≠ВгАМеИЭгАН</div>
      <div class="gm-btn gm-btn-b" onclick="gmMaxRings()">жї°зОѓ(10зОѓ)</div>
    </div>
    <!-- Rings & Bones -->
