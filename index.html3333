// вФАвФАвФАвФА SOUL AWAKENING LEVEL SYSTEM вФАвФАвФАвФА
const AWK_COSTS=[0,5,10,20,35,50,75,100,150,200,300]; // frags of current quality
const AWK_BONUS=[0,200,500,1000,2000,4000,8000,15000,25000,40000,60000]; // power bonus
const AWK_EFFECTS=[
  '','иљ®йБУз≤Те≠РеҐЮеК†','+2жЭ°иљ®йБУ','+жЪЧеЕЙжХИжЮЬ','й≠ВжКАзЙєжХИеҐЮеЉЇ','дЄУе±ЮеЕЙжЩХ',
  'ж≠¶й≠ВеПСеЕЙеҐЮеЉЇ','жЮБеЕЙзЙєжХИ','з≤Те≠РжМБзї≠жХ£еПС','з•ЮзЇІеЕЙиљЃ','вИЮ жЮБйЩРељҐжАБ'
];

function openAwakenLevel(){
  if(!G.soul){notify('иѓЈеЕИиІЙйЖТж≠¶й≠В','normal');return;}
  const lv=G.awakenLevel||0;
  const qc=QC[G.soul.quality]||QC.common;
  const frags=G.soulFragments?.[G.soul.quality]||0;
  const nextCost=lv<10?AWK_COSTS[lv+1]:null;
  const canUp=nextCost&&frags>=nextCost&&lv<10;
  const starsH=Array(10).fill(0).map((_,i)=>`<div class="awk-star ${i<lv?'lit':''}"></div>`).join('');
  const rowsH=Array(10).fill(0).map((_,i)=>{
    const clr=i<lv?qc.c:i===lv?'rgba(255,255,255,.3)':'rgba(255,255,255,.1)';
    return`<div style="display:flex;align-items:center;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:10px;${i<lv?'opacity:.5':''}">
      <span style="color:${clr}">иІЙйЖТ Lv.${i+1}</span>
      <span style="color:var(--dim);font-size:9px">${AWK_EFFECTS[i+1]}</span>
      <span style="color:${i<lv?'var(--hc)':qc.c}">+${AWK_BONUS[i+1].toLocaleString()}</span>
    </div>`;
  }).join('');
  openModal(`<div class="m-title" style="color:${qc.c}">вЬ¶ ж≠¶й≠ВиІЙйЖТз≠ЙзЇІ</div>
    <div class="m-sub">ељУеЙН Lv.${lv}/10 ¬Ј жИШеКЫ+${AWK_BONUS[lv].toLocaleString()}</div>
    <div class="awk-stars" style="justify-content:center;gap:5px;margin:10px 0">${starsH}</div>
    <div style="text-align:center;margin-bottom:10px">
      <div style="font-size:11px;color:var(--dim)">ељУеЙНеУБиі®зҐОзЙЗ: <span style="color:${qc.c};font-weight:700">${frags}</span></div>
      ${nextCost?`<div style="font-size:10px;color:var(--dim);margin-top:3px">еНЗзЇІйЬАи¶Б: <span style="color:${canUp?'var(--hc)':'var(--apex)'}">${nextCost} зҐОзЙЗ</span></div>`:'<div style="font-size:10px;color:var(--hc)">еЈ≤иЊЊжЬАйЂШиІЙйЖТз≠ЙзЇІпЉБ</div>'}
    </div>
    <div style="max-height:220px;overflow-y:auto">${rowsH}</div>
    ${canUp?`<div class="m-acts" style="margin-top:10px">
      <div class="m-btn ok" onclick="doAwakenUp()">иІЙйЖТеНЗзЇІ (жґИиАЧ${nextCost}зҐОзЙЗ)</div>
    </div>`:''}
  `);
}

function doAwakenUp(){
  if(!G.soul)return;
  const lv=G.awakenLevel||0;
  if(lv>=10){notify('еЈ≤иЊЊжЬАйЂШиІЙйЖТз≠ЙзЇІ','normal');return;}
  const cost=AWK_COSTS[lv+1];
  const q=G.soul.quality;
  if((G.soulFragments?.[q]||0)<cost){notify('зҐОзЙЗдЄНиґ≥','normal');return;}
  G.soulFragments[q]-=cost;
  G.awakenLevel=(G.awakenLevel||0)+1;
  G.extraPower+=AWK_BONUS[G.awakenLevel]-AWK_BONUS[G.awakenLevel-1];
  notify(`вЬ¶ ж≠¶й≠ВиІЙйЖТ Lv.${G.awakenLevel}пЉБ${AWK_EFFECTS[G.awakenLevel]}¬ЈжИШеКЫ+${(AWK_BONUS[G.awakenLevel]-AWK_BONUS[G.awakenLevel-1]).toLocaleString()}`,'divine');
  spawnBurst(QC[q]?.c||'#ffd700',80);
  updateHUD();saveG();renderSoulPage();$remCls('modal','show');
  checkAchievement('awaken_lv'+G.awakenLevel);
}


