// Soul evolution chains: {soulName вЖТ {toName, cost(fragments of current quality), reqLv}}
const SOUL_EVOLUTIONS={
  'иУЭйУґиНЙ':    {to:'иУЭйУґзЪЗ',   fragCost:15, reqLv:30, toQ:'legend'},
  'йХ∞еИА':      {to:'йУБйФ§',     fragCost:8,  reqLv:10, toQ:'common'},
  'зЩљиЩО':      {to:'зЩљиЩО',     fragCost:10, reqLv:20, toQ:'rare'},
  'зБЂеЗ§еЗ∞':    {to:'жЮБеУБзБЂеЗ§еЗ∞',fragCost:12, reqLv:40, toQ:'legend'},
  'еЖ∞еЗ§еЗ∞':    {to:'жЮБеУБзБЂеЗ§еЗ∞',fragCost:12, reqLv:40, toQ:'legend'},
  'дЄГеЃЭзРЙзТГе°Ф':{to:'дєЭеЃЭзРЙзТГе°Ф',fragCost:10, reqLv:35, toQ:'legend'},
  'иУЭзФµйЬЄзОЛйЊЩ':{to:'йЗСйЊЩзОЛ',   fragCost:8,  reqLv:45, toQ:'legend'},
  'жШКе§©йФ§':    {to:'жШКе§©дєЭзїЭйФ§',fragCost:6,  reqLv:50, toQ:'ha'},
  'еЕ≠зњЉе§©дљњ':  {to:'з•ЮеЬ£е§©дљњ', fragCost:5,  reqLv:50, toQ:'apex'},
};

function calcResonancePower(){
  if(!G.soulFragments||!G.soulResonance)return 0;
  let total=0;
  Object.entries(G.soulFragments).forEach(([q,count])=>{
    const cfg=RESONANCE_CFG[q];if(!cfg)return;
    const lv=Math.min(cfg.maxLevel,Math.floor(count/cfg.fragPerLevel));
    total+=lv*cfg.powerPerLevel;
  });
  return total;
}

function addSoulFragment(quality, count=1){
  if(!G.soulFragments)G.soulFragments={};
  G.soulFragments[quality]=(G.soulFragments[quality]||0)+count;
  const cfg=RESONANCE_CFG[quality];
  if(cfg){
    const oldLv=Math.min(cfg.maxLevel,Math.floor(((G.soulFragments[quality])-count)/cfg.fragPerLevel));
    const newLv=Math.min(cfg.maxLevel,Math.floor(G.soulFragments[quality]/cfg.fragPerLevel));
    if(newLv>oldLv){
      notify(`вЬ® ж≠¶й≠ВеЕ±йЄ£жПРеНЗпЉБ${QC[quality]?.n||quality}еЕ±йЄ£ Lv.${newLv} ¬Ј жИШеКЫ+${newLv*cfg.powerPerLevel}`,'legend');
      spawnBurst(QC[quality]?.c||'#ffd700',50);
    }
  }
}

function openSoulResonance(){
  if(!G.awakenDone||!G.soul){notify('иѓЈеЕИиІЙйЖТж≠¶й≠В','normal');return;}
  const rows=Object.entries(RESONANCE_CFG).map(([q,cfg])=>{
    const frags=G.soulFragments?.[q]||0;
    const lv=Math.min(cfg.maxLevel,Math.floor(frags/cfg.fragPerLevel));
    const pct=lv>=cfg.maxLevel?100:(frags%cfg.fragPerLevel)/cfg.fragPerLevel*100;
    const pw=lv*cfg.powerPerLevel;
    const qc=QC[q]||QC.common;
    const nextFrag=lv<cfg.maxLevel?(cfg.fragPerLevel-(frags%cfg.fragPerLevel)):0;
    return`<div style="padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04)">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:11px;font-weight:700;color:${qc.c}">${qc.n}</span>
        <span style="font-size:10px;color:var(--gold)">Lv.${lv}/${cfg.maxLevel} ¬Ј +${pw.toLocaleString()}</span>
      </div>
      <div style="height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;margin-bottom:3px">
        <div style="height:100%;width:${pct}%;background:${qc.c};border-radius:2px;transition:width .4s"></div>
      </div>
      <div style="font-size:9px;color:var(--dim)">зҐОзЙЗ: ${frags}${lv<cfg.maxLevel?` ¬Ј еНЗзЇІињШйЬА ${nextFrag} зҐОзЙЗ`:'¬Ј еЈ≤жї°зЇІ'}</div>
    </div>`;
  }).join('');

  const sourcesH=FRAGMENT_SOURCES.map(s=>`
    <div style="display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.03)">
      <span style="font-size:14px;flex-shrink:0">${s.icon}</span>
      <div>
        <div style="font-size:10px;font-weight:600;color:var(--txt)">${s.label}</div>
        <div style="font-size:9px;color:var(--dim)">${s.desc}</div>
      </div>
    </div>`).join('');

  const totalPow=calcResonancePower();
  openModal(`<div class="m-title">вЬ® ж≠¶й≠ВеЕ±йЄ£</div>
    <div class="m-sub">жАїеЕ±йЄ£жИШеКЫ +${totalPow.toLocaleString()}</div>
    <div style="margin-bottom:10px">${rows}</div>
    <div class="m-sec-t" style="margin:10px 0 6px">зҐОзЙЗиОЈеПЦйАФеЊД</div>
    <div>${sourcesH}</div>`);
}

function openSoulEvolution(){
  if(!G.awakenDone||!G.soul){notify('иѓЈеЕИиІЙйЖТж≠¶й≠В','normal');return;}
  const ev=SOUL_EVOLUTIONS[G.soul.name];
  const frags=G.soulFragments?.[G.soul.quality]||0;
  if(!ev){
    openModal(`<div class="m-title">рЯМЯ ж≠¶й≠ВдЉ†жЙњ</div>
      <div class="m-sub" style="color:var(--dim)">ељУеЙНж≠¶й≠ВжЪВжЧ†дЉ†жЙњйУЊ</div>
      <div style="font-size:11px;color:var(--dim);text-align:center;padding:20px;line-height:1.8">
        ${G.soul.name} жЪВжЧ†еЈ≤зЯ•дЉ†жЙњељҐжАБгАВ<br>
        зЙєжЃКж≠¶й≠ВгАБеПМзФЯж≠¶й≠ВеПѓйАЪињЗеЕґдїЦжЦєеЉПињЫеМЦгАВ<br><br>
        <span style="color:var(--gl)">еЈ≤жЬЙзҐОзЙЗпЉЪ${frags} жЮЪ</span>
      </div>`);
    return;
  }
  const canEvolve=frags>=ev.fragCost&&G.level>=ev.reqLv;
  openModal(`<div class="m-title" style="color:var(--gl)">рЯМЯ ж≠¶й≠ВдЉ†жЙњ</div>
    <div class="m-sub">${G.soul.icon} ${G.soul.name} вЖТ ${ev.to}</div>
    <div style="display:flex;align-items:center;justify-content:center;gap:16px;padding:16px 0">
      <div style="text-align:center">
        <div style="font-size:44px">${G.soul.icon}</div>
        <div style="font-size:11px;color:var(--dim);margin-top:4px">${G.soul.name}</div>
      </div>
      <div style="font-size:22px;color:var(--gl)">вЖТ</div>
      <div style="text-align:center">
        <div style="font-size:44px">вЬ®</div>
        <div style="font-size:11px;color:${QC[ev.toQ]?.c||'var(--gl)'};margin-top:4px">${ev.to}</div>
      </div>
    </div>
    <div class="m-ag" style="margin-bottom:12px">
      <div class="m-at"><div class="m-an">жЙАйЬАзҐОзЙЗ</div><div class="m-av" style="color:${frags>=ev.fragCost?'var(--hc)':'var(--apex)'}">${frags}/${ev.fragCost}</div></div>
      <div class="m-at"><div class="m-an">з≠ЙзЇІи¶Бж±В</div><div class="m-av" style="color:${G.level>=ev.reqLv?'var(--hc)':'var(--apex)'}">Lv.${G.level}/${ev.reqLv}</div></div>
    </div>
    <div class="m-acts">
      <div class="m-btn ok" style="${canEvolve?'':'opacity:.4;pointer-events:none'}" onclick="execSoulEvolution()">дЉ†жЙњињЫеМЦ</div>
    </div>`);
}

function execSoulEvolution(){
  if(!G.soul)return;
  const ev=SOUL_EVOLUTIONS[G.soul.name];if(!ev)return;
  const frags=G.soulFragments?.[G.soul.quality]||0;
  if(frags<ev.fragCost||G.level<ev.reqLv){notify('жЭ°дїґдЄНжї°иґ≥','normal');return;}
  G.soulFragments[G.soul.quality]-=ev.fragCost;
  // Find the target soul in SD
  const newQ=ev.toQ;
  const newSd=SD[newQ]?.find(s=>s.n===ev.to)||(SD[newQ]?.[0]);
  if(!newSd){notify('дЉ†жЙњзЫЃж†ЗдЄНе≠ШеЬ®','normal');return;}
  const oldName=G.soul.name;
  G.soul.name=newSd.n;G.soul.icon=newSd.i;G.soul.quality=newQ;
  G.soul.desc=newSd.d;G.soul.attrs=[...newSd.a,...(G.soul.attrs||[])].slice(0,8);
  G.soul.divine=G.soul.divine||['apex','ha','twin','triple'].includes(newQ);
  addExp(5000);G.extraPower+=2000;
  grimoireDiscover(newSd.n,newQ);
  notify(`рЯМЯ ${oldName} дЉ†жЙњдЄЇ ${newSd.n}пЉБж≠¶й≠ВињЫеМЦжИРеКЯпЉБжИШеКЫ+2000`,'divine');
  spawnBurst(QC[newQ]?.c||'#ffd700',120);
  $remCls('modal','show');
  saveG();renderSoulPage();
}

