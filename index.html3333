function openTalentSelect(){
  if(G.level<91){notify('йЬАи¶БиЊЊеИ∞е∞БеПЈжЦЧзљЧпЉИLv.91пЉЙжЙНиГљиІЙйЖТе∞БеПЈе§©иµЛпЉБ','normal');return;}
  const hasSelected=!!G.talent;
  const resetCost=G.talentResetCost||50000;
  const cardsH=TALENTS.map(t=>`
    <div class="talent-card ${G.talent===t.id?'selected':''}"
      style="--tc:${t.col};--tr:${t.tr};--tg:${t.tg};--tb:${t.tb}"
      onclick="selectTalent('${t.id}')">
      ${G.talent===t.id?'<div class="tc-active-badge">еЈ≤йАЙ</div>':''}
      <div class="tc-ico">${t.icon}</div>
      <div class="tc-name">${t.name}</div>
      <div class="tc-desc">${t.desc}</div>
      <div class="tc-stats">${t.stats.map(s=>`<div class="tc-stat">вЦґ ${s}</div>`).join('')}</div>
    </div>`).join('');
  openModal(`<div class="m-title" style="color:var(--gold)">вЪФпЄП е∞БеПЈе§©иµЛ</div>
    <div class="m-sub">${hasSelected?'ељУеЙНпЉЪ'+TALENTS.find(t=>t.id===G.talent)?.name||'':'йАЙжЛ©дљ†зЪДе∞БеПЈе§©иµЛжЦєеРСпЉМLv.91дЄУе±Ю'}</div>
    <div class="talent-grid">${cardsH}</div>
    ${hasSelected?`<div style="margin-top:10px;text-align:center;font-size:10px;color:var(--dim)">
      йЗНзљЃе§©иµЛйЬАжґИиАЧ <span style="color:var(--apex)">${resetCost.toLocaleString()} й≠ВеКЫ</span>
      <span onclick="resetTalent()" style="color:var(--apex);cursor:pointer;margin-left:8px;border:1px solid rgba(239,68,68,.3);padding:2px 8px;border-radius:5px">йЗНзљЃ</span>
    </div>`:''}
  `);
}

function selectTalent(id){
  if(G.talent&&G.talent!==id){notify('еЈ≤жЬЙе§©иµЛпЉМиѓЈеЕИйЗНзљЃпЉБ','normal');return;}
  const t=TALENTS.find(x=>x.id===id);if(!t)return;
  G.talent=id;
  notify(`рЯФ• е∞БеПЈе§©иµЛгАМ${t.name}гАНеЈ≤иІЙйЖТпЉБ${t.stats[0]}пЉБ`,'divine');
  spawnBurst(t.col,100);
  // Apply support talent token bonus immediately
  if(id==='support'){G.abyss.maxTokens=Math.min(20,G.abyss.maxTokens+2);$set('ab-tokens','textContent',G.abyss.tokens);}
  updateHUD();saveG();renderSoulPage();$remCls('modal','show');
}

function resetTalent(){
  const cost=G.talentResetCost||50000;
  if(G.sp<cost){notify('й≠ВеКЫдЄНиґ≥пЉМйЗНзљЃйЬАи¶Б'+cost.toLocaleString()+'й≠ВеКЫ','normal');return;}
  if(!confirm('з°ЃиЃ§иК±иіє'+cost.toLocaleString()+'й≠ВеКЫйЗНзљЃе∞БеПЈе§©иµЛпЉЯ'))return;
  G.sp-=cost;G.talent=null;G.talentResetCost=(G.talentResetCost||50000)*3;
  notify('е§©иµЛеЈ≤йЗНзљЃпЉМеПѓйЗНжЦ∞йАЙжЛ©','normal');
  updateHUD();saveG();openTalentSelect();
}

function getTalentBonus(){
  if(!G.talent)return{};
  return TALENTS.find(t=>t.id===G.talent)?.combatBonus||{};
}

